# PolyEdge 后端本地环境变量示例。
# 复制为 packages/backend/.env。只覆盖本地运行常用项，其余使用代码默认值。
# Rewards 报价、copytrade、news 等业务参数可在 Settings -> Runtime Configuration 调整。

# ── HTTP / 存储 ────────────────────────────────────────────────────────────
POLYEDGE_SERVER__HOST=0.0.0.0
POLYEDGE_SERVER__PORT=38001

# 留空会使用 in-memory store；需要多进程共享状态、迁移和真实 worker 时请配置 PostgreSQL。
POLYEDGE_POSTGRES__URL=
POLYEDGE_POSTGRES__MAX_CONNECTIONS=20

POLYEDGE_RUNTIME__ENVIRONMENT=local
POLYEDGE_RUNTIME__INITIAL_MODE=paper_trade

# ── 本地鉴权 ──────────────────────────────────────────────────────────────
# 本地开发默认关闭 API 鉴权。要测试 JWT/step-up，把 disabled 改为 false 并配置 keys/code。
POLYEDGE_AUTH__DISABLED=true
# POLYEDGE_AUTH__STEP_UP_CODE=change-me
# POLYEDGE_AUTH__KEYS_JSON=[{"kid":"local","public_key_base64":"<base64-ed25519-public-key>"}]

# ── Orderbook 服务 ────────────────────────────────────────────────────────
# cargo run -p polyedge-orderbook 会读取同一个 .env；write token 需与 API/worker 一致。
POLYEDGE_ORDERBOOK__SERVICE_URL=http://127.0.0.1:38002
POLYEDGE_ORDERBOOK__WRITE_TOKEN=dev-change-me

# ── 子系统总开关 ──────────────────────────────────────────────────────────
POLYEDGE_NEWS__ENABLED=false
POLYEDGE_REWARDS__ENABLED=false
POLYEDGE_COPYTRADE__ENABLED=false

# ── API 内嵌 worker runtime：本地默认不启动后台循环 ────────────────────────
POLYEDGE_WORKER__POLL_NEWS=false
POLYEDGE_WORKER__PROMOTE_NEWS_EVENTS=false

POLYEDGE_WORKER__POLL_REWARD_BOT=false
POLYEDGE_WORKER__POLL_REWARD_INFO_RISKS=false

POLYEDGE_WORKER__POLL_COPYTRADE=false
POLYEDGE_WORKER__ANALYZE_WALLETS=false
POLYEDGE_WORKER__POLL_SMART_MONEY=false
POLYEDGE_WORKER__SMART_MONEY_INTERVAL_SECS=900
POLYEDGE_WORKER__POLL_HIGH_PROBABILITY_OBSERVE=false
POLYEDGE_WORKER__HIGH_PROBABILITY_OBSERVE_INTERVAL_SECS=300

POLYEDGE_WORKER__DATABASE_MAINTENANCE=false
POLYEDGE_WORKER__DATABASE_MAINTENANCE_INTERVAL_SECS=3600

POLYEDGE_WORKER__DRAIN_EXECUTION_QUEUE=false
POLYEDGE_WORKER__POLL_PAPER_ORDER_STATUSES=false
POLYEDGE_WORKER__RECONCILE_PAPER_FILLS=false
POLYEDGE_WORKER__POLL_POLYMARKET_ORDER_STATUSES=false
POLYEDGE_WORKER__RECONCILE_POLYMARKET_FILLS=false
POLYEDGE_WORKER__CONSUME_POLYMARKET_USER_EVENTS=false

# ── Polymarket live / funding 凭证（可选）────────────────────────────────
# Rewards live、私有订单/成交任务或 Funding API 入金前必须配置真实账户，并先做小额验证。
# POLYEDGE_POLYMARKET__ACCOUNT_ID=0xYourAccount
# POLYEDGE_POLYMARKET__SIGNATURE_TYPE=eoa
# Funding API 入账钱包优先使用 FUNDER，未配置时回退 ACCOUNT_ID。
# POLYEDGE_POLYMARKET__FUNDER=0xYourFunderOrDepositWallet
# PRIVATE_KEY 对应后端资金钱包；Funding API 会用它签名真实 Polygon USDC/USDT 转账。
# POLYEDGE_POLYMARKET__PRIVATE_KEY=0xYourPrivateKey
# POLYEDGE_POLYMARKET__API_KEY=replace-with-clob-api-key
# POLYEDGE_POLYMARKET__API_SECRET=replace-with-clob-api-secret
# POLYEDGE_POLYMARKET__API_PASSPHRASE=replace-with-clob-api-passphrase
# POLYGON_RPC_URL 同时用于 pUSD 余额回退和 Funding API 广播 Polygon 转账。
# POLYEDGE_POLYMARKET__POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# ── Rewards AI / 信息风险 provider（可选）────────────────────────────────
# OpenAI-compatible provider key。GLM/DeepSeek 也使用这组 key/base/model，由模型名触发兼容请求形态。
# POLYEDGE_REWARDS__AI_OPENAI_API_KEY=replace-with-openai-compatible-api-key
# POLYEDGE_REWARDS__AI_OPENAI_BASE_URL=https://api.openai.com/v1
# POLYEDGE_REWARDS__AI_MODEL=gpt-4.1-mini
# GLM 示例：
# POLYEDGE_REWARDS__AI_OPENAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# POLYEDGE_REWARDS__AI_MODEL=glm-4.7
# DeepSeek 示例：
# POLYEDGE_REWARDS__AI_OPENAI_BASE_URL=https://api.deepseek.com
# POLYEDGE_REWARDS__AI_MODEL=deepseek-v4-flash
# POLYEDGE_REWARDS__AI_ANTHROPIC_API_KEY=replace-with-anthropic-api-key
# POLYEDGE_REWARDS__INFO_RISK_WEB_SEARCH_ENABLED=false

# ── Rewards AI provider 备用接口（可选）─────────────────────────────────
# 主接口调用任意失败时，用同一请求重试此备用接口（可不同 provider/模型）。五项同时配置才启用。
# GLM/DeepSeek 备用接口同样设置 provider=openai，并通过 fallback base URL + model 区分。
# POLYEDGE_REWARDS__AI_FALLBACK_PROVIDER=openai
# POLYEDGE_REWARDS__AI_FALLBACK_REQUEST_FORMAT=openai_chat_completions
# POLYEDGE_REWARDS__AI_FALLBACK_API_KEY=replace-with-fallback-api-key
# POLYEDGE_REWARDS__AI_FALLBACK_BASE_URL=https://api.deepseek.com
# POLYEDGE_REWARDS__AI_FALLBACK_MODEL=deepseek-v4-flash

# ── 新闻源（可选）─────────────────────────────────────────────────────────
# 未设置时使用代码内置 RSS/Atom 默认源；设置该变量会覆盖整个源列表。
# POLYEDGE_NEWS__SOURCES_JSON=[{"id":"example","source_type":"official","url":"https://example.com/feed.xml","reliability":"0.95","enabled":true}]
