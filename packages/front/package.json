{
  "name": "front",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--require ./scripts/suppress-dep0205.cjs\" next dev --hostname 0.0.0.0 --port 33002",
    "dev:webpack": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--require ./scripts/suppress-dep0205.cjs\" next dev --webpack --hostname 0.0.0.0 --port 33002",
    "build": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--require ./scripts/suppress-dep0205.cjs\" next build",
    "start": "node -e \"console.error('This frontend is exported as static files. Use the nginx Docker image or serve ./out with a static file server.'); process.exit(1)\"",
    "lint": "eslint",
    "test:radar-state": "rm -rf .tmp/radar-state-test && tsc -p tsconfig.radar-test.json && node --test .tmp/radar-state-test/features/radar/lib/radar-state.test.js"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5"
  }
}
