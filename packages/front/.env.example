# PolyEdge 前端环境变量示例。
# 本地运行 Next.js 时，可复制为 packages/front/.env。

# Next.js dev server 的监听地址。
HOSTNAME=0.0.0.0

# 静态部署默认使用同源 /api/v1，由 Nginx 代理到后端。
# 只有在本地浏览器直接请求 Rust API 时才需要设置该公开构建变量。
NEXT_PUBLIC_POLYEDGE_API_BASE_URL=

# 控制台路由保护模式。当前前端只保留 off；生产级 session provider 尚未接入。
NEXT_PUBLIC_POLYEDGE_CONSOLE_AUTH=off

# 本地后端认证绕过开关。为 1 时，前端发送 dev-auth header，而不是签发内部 JWT。
# 仅应与 local 后端环境和空的 POLYEDGE_AUTH__KEYS_JSON 搭配使用。
NEXT_PUBLIC_POLYEDGE_INTERNAL_AUTH_DEV_BYPASS=1
