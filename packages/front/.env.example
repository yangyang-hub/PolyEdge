# PolyEdge 前端环境变量示例。
# 本地运行 Next.js 时，可复制为 packages/front/.env。

# Next.js/standalone server 的监听地址。0.0.0.0 表示允许从本机外部网络访问；部署前请确认防火墙和反向代理策略。
HOSTNAME=0.0.0.0

# 后端 API 基础地址。前端不再提供 mock 数据模式，读写和 SSE 都必须配置真实后端。
# 本地联调 Rust API 可设为 http://127.0.0.1:38001；Docker 中应设为 API service 地址。
POLYEDGE_API_BASE_URL=

# 控制台路由保护模式。当前前端只保留 off；生产级 session provider 尚未接入。
POLYEDGE_CONSOLE_AUTH=off

# off 模式下，受保护控制台操作需要输入的本地 step-up code。共享环境必须修改。
POLYEDGE_CONSOLE_STEP_UP_CODE=000000

# 本地后端认证绕过开关。为 1 时，前端发送 dev-auth header，而不是签发内部 JWT。
# 仅应与 local 后端环境和空的 POLYEDGE_AUTH__KEYS_JSON 搭配使用。
POLYEDGE_INTERNAL_AUTH_DEV_BYPASS=1
# 关闭 dev bypass 后，内部 JWT 使用的 issuer；必须与后端 POLYEDGE_AUTH__ISSUER 一致。
POLYEDGE_INTERNAL_AUTH_ISSUER=polyedge-nextjs
# 关闭 dev bypass 后，内部 JWT 使用的 audience；必须与后端 POLYEDGE_AUTH__AUDIENCE 一致。
POLYEDGE_INTERNAL_AUTH_AUDIENCE=polyedge-rust-api
# 内部 JWT 使用的 key id；必须匹配后端 POLYEDGE_AUTH__KEYS_JSON 中的一项。
POLYEDGE_INTERNAL_AUTH_KID=
# 用于签发内部 API JWT 的 Ed25519 私钥，可使用 base64 或 PEM。不要提交真实密钥。
POLYEDGE_INTERNAL_AUTH_PRIVATE_KEY=
