# PolyEdge 前端环境变量示例。
# 本地运行 Next.js 时，可复制为 packages/front/.env。

# Next.js dev server 的监听地址。
HOSTNAME=0.0.0.0

# Rust API 直连地址。前端和 API 分别部署在不同内网服务器时必须设置。
# 示例：http://192.168.31.5:38001
NEXT_PUBLIC_POLYEDGE_API_BASE_URL=http://127.0.0.1:38001

# 控制台路由保护模式。当前前端只保留 off；生产级 session provider 尚未接入。
NEXT_PUBLIC_POLYEDGE_CONSOLE_AUTH=off

# 旧 local dev-auth 绕过开关。当前纯内网部署使用 POLYEDGE_AUTH__DISABLED=true，
# 前端不需要发送 dev-auth header。
NEXT_PUBLIC_POLYEDGE_INTERNAL_AUTH_DEV_BYPASS=0
