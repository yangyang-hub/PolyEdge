# PolyEdge 前端控制台环境变量。
# 复制为 deploy/.env.front。
# 前端是静态 SPA；NEXT_PUBLIC_* 会在 yarn build 时写入浏览器 bundle。
# 修改 NEXT_PUBLIC_* 后必须重新运行部署脚本重建前端镜像。

# 可选：覆盖前端镜像 tag；未配置时 docker-compose 使用 polyedge-front:local。
# POLYEDGE_FRONT_IMAGE=polyedge-front:local

# 可选：前端 Nginx 暴露到宿主机的监听地址；只影响 Docker 端口映射。
# POLYEDGE_FRONT_BIND=0.0.0.0

# 可选：前端 Nginx 暴露到宿主机的端口，映射到容器内 80。
# POLYEDGE_FRONT_PORT=33002

# 单体后端直连地址，浏览器会直接访问；必须包含协议和端口，不以 / 结尾。
# 默认生产排查入口为 http://192.168.31.5:33002，该前端应指向下面的后端地址。
NEXT_PUBLIC_POLYEDGE_API_BASE_URL=http://100.87.45.72:38001

# 控制台路由保护模式。当前前端只保留 off；生产级 session provider 尚未接入。
NEXT_PUBLIC_POLYEDGE_CONSOLE_AUTH=off

# 可选：旧 local dev-auth bypass；只有 API 为 local 且未关闭鉴权时才可能使用，内网部署不要设置。
# NEXT_PUBLIC_POLYEDGE_INTERNAL_AUTH_DEV_BYPASS=1
