# PolyEdge 前端控制台环境变量。
# 复制为 deploy/.env.front。
# 前端是静态 SPA；NEXT_PUBLIC_* 会在 yarn build 时写入浏览器 bundle。
# 修改 NEXT_PUBLIC_* 后必须重新运行部署脚本重建前端镜像。

# 可选：覆盖前端镜像 tag；未配置时 docker-compose 使用 polyedge-front:local。
# POLYEDGE_FRONT_IMAGE=polyedge-front:local

# 可选：前端 Nginx 暴露到宿主机的监听地址；只影响 Docker 端口映射。
# POLYEDGE_FRONT_BIND=0.0.0.0

# 可选：前端 Nginx 暴露到宿主机的端口，映射到容器内 80。
# POLYEDGE_FRONT_PORT=33002

# Nginx 同源 /api 的后端 upstream。默认连接同一 Compose 网络的 server；前后端拆机时
# 改为 http://<后端内网 IP>:38001。只能填写无 path/query/fragment 的精确 HTTP(S) origin。
POLYEDGE_FRONT_API_UPSTREAM=http://polyedge-server:38001

# 必须留空：生产静态站点使用 Nginx 同源 /api 反向代理，CSP 和 Cookie session
# 均不支持把跨 origin API 地址构建进浏览器 bundle。本地开发覆盖见 packages/front/.env.example。
NEXT_PUBLIC_POLYEDGE_API_BASE_URL=
