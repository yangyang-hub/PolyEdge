# PolyEdge 前端控制台环境变量。
# 与 .env（公共变量）配合使用。
#
# 前端为纯静态 SPA（Next.js export），由 nginx 托管静态文件。
# API 调用由浏览器直连后端，不再经过 nginx 反代。
# 前端构建时需要设置以下 NEXT_PUBLIC_ 变量：

# POLYEDGE_FRONT_BIND：
# 前端 Nginx 暴露到宿主机的监听地址。0.0.0.0 表示所有网卡可访问。
# POLYEDGE_FRONT_BIND=0.0.0.0

# POLYEDGE_FRONT_PORT：
# 前端控制台暴露到宿主机的端口，映射到容器内 Nginx 80。
# POLYEDGE_FRONT_PORT=33002

# ── 以下变量在 yarn build 时作为 NEXT_PUBLIC_ 前缀注入前端代码 ──────────────

# NEXT_PUBLIC_POLYEDGE_API_BASE_URL：
# 后端 API 直连地址（浏览器直接访问）。必须包含协议和端口，不以 / 结尾。
# 例：http://192.168.31.5:38001
# NEXT_PUBLIC_POLYEDGE_API_BASE_URL=http://192.168.31.5:38001

# NEXT_PUBLIC_POLYEDGE_INTERNAL_AUTH_DEV_BYPASS：
# 设为 1 时，前端自动发送 dev auth 头（X-PolyEdge-Dev-Auth / Console-Role / Console-User）。
# 仅限内网 local 环境使用，生产环境必须关闭。
# NEXT_PUBLIC_POLYEDGE_INTERNAL_AUTH_DEV_BYPASS=1
