# PolyEdge API 内嵌 worker runtime 的环境变量。
# 由 polyedge-api 容器与 .env（公共变量）一起加载，不再对应独立 worker 容器。
#
# 后台任务默认在 Docker 部署中关闭；需要时显式改成 true。


# ── 新闻 ────────────────────────────────────────────────────────────────────
# POLYEDGE_WORKER__POLL_NEWS：
# 启用新闻抓取 worker 循环。默认关闭，开启后会从配置的新闻源写入后端存储。
# POLYEDGE_WORKER__POLL_NEWS=false

# POLYEDGE_WORKER__PROMOTE_NEWS_EVENTS：
# 启用新闻提升为 events/evidences 的 worker 循环。通常和 POLL_NEWS 分阶段开启。
# POLYEDGE_WORKER__PROMOTE_NEWS_EVENTS=false

# ── 套利 ────────────────────────────────────────────────────────────────────
# POLYEDGE_WORKER__POLL_ARBITRAGE_RADAR：
# 启用套利雷达扫描循环。当前套利链路只发现/记录/展示，不会自动下单。
# POLYEDGE_WORKER__POLL_ARBITRAGE_RADAR=false

# POLYEDGE_WORKER__ANALYZE_ARBITRAGE_OPPORTUNITIES：
# 启用套利机会分析循环，用于对已发现机会做后续评估。
# POLYEDGE_WORKER__ANALYZE_ARBITRAGE_OPPORTUNITIES=false

# ── Rewards live ──────────────────────────────────────────────────────────
# POLYEDGE_WORKER__POLL_REWARD_BOT：
# 启用 rewards worker 主循环，领取 Run/Cancel/Reset 命令并执行 live tick。
# POLYEDGE_WORKER__POLL_REWARD_BOT=false

# POLYEDGE_REWARDS__AI_OPENAI_API_KEY：
# 可选。Rewards AI advisory 使用 OpenAI 格式时的 API key；只放 worker 环境，不放 API/front。
# POLYEDGE_REWARDS__AI_OPENAI_API_KEY=replace-with-openai-api-key

# POLYEDGE_REWARDS__AI_ANTHROPIC_API_KEY：
# 可选。Rewards AI advisory 使用 Anthropic Messages 格式时的 API key；只放 worker 环境。
# POLYEDGE_REWARDS__AI_ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# POLYEDGE_REWARDS__AI_OPENAI_BASE_URL：
# OpenAI 兼容接口 base URL。默认 https://api.openai.com/v1。
# POLYEDGE_REWARDS__AI_OPENAI_BASE_URL=https://api.openai.com/v1

# POLYEDGE_REWARDS__AI_ANTHROPIC_BASE_URL：
# Anthropic API base URL。默认 https://api.anthropic.com。
# POLYEDGE_REWARDS__AI_ANTHROPIC_BASE_URL=https://api.anthropic.com

# POLYEDGE_REWARDS__AI_MODEL：
# Rewards AI advisory 使用的模型名。默认 gpt-4.1-mini；Anthropic provider 时应改为对应模型。
# POLYEDGE_REWARDS__AI_MODEL=gpt-4.1-mini

# POLYEDGE_REWARDS__AI_MIN_CONFIDENCE_BPS：
# AI 建议被 enforce 前的最低置信度，单位 bps；6500 表示 65%。默认 6500。
# POLYEDGE_REWARDS__AI_MIN_CONFIDENCE_BPS=6500

# POLYEDGE_REWARDS__AI_REQUEST_TIMEOUT_SECS：
# 单次 AI advisory 请求超时秒数。默认 20。
# POLYEDGE_REWARDS__AI_REQUEST_TIMEOUT_SECS=20

# POLYEDGE_REWARDS__AI_MAX_MARKETS_PER_CYCLE：
# 每个 rewards full tick 最多请求 AI 判断的市场数；其余市场保留确定性计划。默认 12。
# POLYEDGE_REWARDS__AI_MAX_MARKETS_PER_CYCLE=12

# POLYEDGE_WORKER__POLL_REWARD_INFO_RISKS：
# 启用 rewards 信息风险异步扫描。只写数据库缓存，不直接下单或撤单。
# POLYEDGE_WORKER__POLL_REWARD_INFO_RISKS=false

# POLYEDGE_REWARDS__INFO_RISK_INTERVAL_SECS：
# 信息风险扫描间隔秒数。默认 300。
# POLYEDGE_REWARDS__INFO_RISK_INTERVAL_SECS=300

# POLYEDGE_REWARDS__INFO_RISK_MAX_MARKETS_PER_CYCLE：
# 每轮信息风险最多请求 provider 判断的市场数。默认 12。
# POLYEDGE_REWARDS__INFO_RISK_MAX_MARKETS_PER_CYCLE=12

# POLYEDGE_REWARDS__INFO_RISK_MIN_CONFIDENCE_BPS：
# 信息风险在 enforce 模式影响计划前的最低置信度，7000 表示 70%。默认 7000。
# POLYEDGE_REWARDS__INFO_RISK_MIN_CONFIDENCE_BPS=7000

# POLYEDGE_REWARDS__INFO_RISK_WEB_SEARCH_ENABLED：
# 可选。仅 OpenAI Responses 格式下启用 web_search_preview 工具；默认 false。
# POLYEDGE_REWARDS__INFO_RISK_WEB_SEARCH_ENABLED=false

# POLYEDGE_WORKER__DRAIN_EXECUTION_QUEUE：
# 启用通用 execution queue drain。Rewards 当前 live 直接走 connector 下单，通常不依赖它。
# POLYEDGE_WORKER__DRAIN_EXECUTION_QUEUE=false

# ── 跟单 ────────────────────────────────────────────────────────────────────
# POLYEDGE_WORKER__POLL_COPYTRADE：
# 启用 copy-trading 跟单 worker 主循环，领取跟单 Run/Cancel/Reset 命令。
# POLYEDGE_WORKER__POLL_COPYTRADE=false

# POLYEDGE_WORKER__ANALYZE_WALLETS：
# 启用被跟踪钱包分析循环，通过 Polymarket Data API 更新钱包统计。
# POLYEDGE_WORKER__ANALYZE_WALLETS=false

# ── Polymarket 订单/成交 ────────────────────────────────────────────────────
# POLYEDGE_WORKER__POLL_PAPER_ORDER_STATUSES：
# 启用 paper/simulation 订单状态轮询。只用于模拟执行链路，不访问真实交易所订单。
# POLYEDGE_WORKER__POLL_PAPER_ORDER_STATUSES=false

# POLYEDGE_WORKER__RECONCILE_PAPER_FILLS：
# 启用 paper/simulation 成交对账。只更新模拟成交和本地状态。
# POLYEDGE_WORKER__RECONCILE_PAPER_FILLS=false

# POLYEDGE_WORKER__POLL_POLYMARKET_ORDER_STATUSES：
# 启用真实 Polymarket 订单状态轮询。需要真实 CLOB API 凭证和私钥配置。
# POLYEDGE_WORKER__POLL_POLYMARKET_ORDER_STATUSES=false

# POLYEDGE_WORKER__RECONCILE_POLYMARKET_FILLS：
# 启用真实 Polymarket 成交对账。需要真实 CLOB API 凭证；开启前应先小额验证。
# POLYEDGE_WORKER__RECONCILE_POLYMARKET_FILLS=false

# POLYEDGE_WORKER__CONSUME_POLYMARKET_USER_EVENTS：
# 启用真实 Polymarket 私有 user events websocket 消费。需要真实账户凭证。
# POLYEDGE_WORKER__CONSUME_POLYMARKET_USER_EVENTS=false

# ── 信号 ────────────────────────────────────────────────────────────────────
# POLYEDGE_WORKER__RECOMPUTE_SIGNALS：
# 启用信号重算 worker 循环。当前 signals/news 仍有未完成链路，默认关闭。
# POLYEDGE_WORKER__RECOMPUTE_SIGNALS=false

# ── Orderbook 服务地址 ──────────────────────────────────────────────────────
# POLYEDGE_ORDERBOOK__SERVICE_URL：
# 由 deploy/.env.api 配置，API 内嵌 runtime 用它读取盘口和注册 token。
# 同一 Compose 项目使用 http://polyedge-orderbook:38002；跨服务器使用实际地址。

# POLYEDGE_ORDERBOOK__WRITE_TOKEN：
# API 内嵌 runtime 注册 orderbook token 时使用的共享密钥。必须与 orderbook 服务一致；不要放入公共 .env。
POLYEDGE_ORDERBOOK__WRITE_TOKEN=change-me

# ── 推荐配置示例 ────────────────────────────────────────────────────────────
# Rewards live 要执行策略 tick 和撤单/重置命令，至少需要开启 rewards poll。
# 还需要真实 Polymarket 凭证；Rewards 仅支持 live，配置中已没有 execution_mode。
# Polymarket live / Deposit Wallet 示例见 deploy/.env.polymarket.example。
# POLYEDGE_WORKER__POLL_REWARD_BOT：
# 推荐开启 rewards 时设为 true；不运行 rewards worker 时保持 false。
# POLYEDGE_WORKER__POLL_REWARD_BOT=true
