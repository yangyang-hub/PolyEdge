# PolyEdge Worker 服务环境变量。
# 与 .env（公共变量）配合使用。
#
# 后台任务默认在 Docker 部署中关闭；需要时显式改成 true。


# ── 新闻 ────────────────────────────────────────────────────────────────────
# POLYEDGE_WORKER__POLL_NEWS：
# 启用新闻抓取 worker 循环。默认关闭，开启后会从配置的新闻源写入后端存储。
# POLYEDGE_WORKER__POLL_NEWS=false

# POLYEDGE_WORKER__PROMOTE_NEWS_EVENTS：
# 启用新闻提升为 events/evidences 的 worker 循环。通常和 POLL_NEWS 分阶段开启。
# POLYEDGE_WORKER__PROMOTE_NEWS_EVENTS=false

# ── 套利 ────────────────────────────────────────────────────────────────────
# POLYEDGE_WORKER__POLL_ARBITRAGE_RADAR：
# 启用套利雷达扫描循环。当前套利链路只发现/记录/展示，不会自动下单。
# POLYEDGE_WORKER__POLL_ARBITRAGE_RADAR=false

# POLYEDGE_WORKER__ANALYZE_ARBITRAGE_OPPORTUNITIES：
# 启用套利机会分析循环，用于对已发现机会做后续评估。
# POLYEDGE_WORKER__ANALYZE_ARBITRAGE_OPPORTUNITIES=false

# ── Rewards validation/live ────────────────────────────────────────────────
# POLYEDGE_WORKER__POLL_REWARD_BOT：
# 启用 rewards worker 主循环，领取 Run/Cancel/Reset 命令并执行 validation/live tick。
# POLYEDGE_WORKER__POLL_REWARD_BOT=false

# POLYEDGE_WORKER__DRAIN_EXECUTION_QUEUE：
# 启用通用 execution queue drain。Rewards 当前 live 直接走 connector 下单，通常不依赖它。
# POLYEDGE_WORKER__DRAIN_EXECUTION_QUEUE=false

# ── 跟单 ────────────────────────────────────────────────────────────────────
# POLYEDGE_WORKER__POLL_COPYTRADE：
# 启用 copy-trading 跟单 worker 主循环，领取跟单 Run/Cancel/Reset 命令。
# POLYEDGE_WORKER__POLL_COPYTRADE=false

# POLYEDGE_WORKER__ANALYZE_WALLETS：
# 启用被跟踪钱包分析循环，通过 Polymarket Data API 更新钱包统计。
# POLYEDGE_WORKER__ANALYZE_WALLETS=false

# ── Polymarket 订单/成交 ────────────────────────────────────────────────────
# POLYEDGE_WORKER__POLL_PAPER_ORDER_STATUSES：
# 启用 paper/simulation 订单状态轮询。只用于模拟执行链路，不访问真实交易所订单。
# POLYEDGE_WORKER__POLL_PAPER_ORDER_STATUSES=false

# POLYEDGE_WORKER__RECONCILE_PAPER_FILLS：
# 启用 paper/simulation 成交对账。只更新模拟成交和本地状态。
# POLYEDGE_WORKER__RECONCILE_PAPER_FILLS=false

# POLYEDGE_WORKER__POLL_POLYMARKET_ORDER_STATUSES：
# 启用真实 Polymarket 订单状态轮询。需要真实 CLOB API 凭证和私钥配置。
# POLYEDGE_WORKER__POLL_POLYMARKET_ORDER_STATUSES=false

# POLYEDGE_WORKER__RECONCILE_POLYMARKET_FILLS：
# 启用真实 Polymarket 成交对账。需要真实 CLOB API 凭证；开启前应先小额验证。
# POLYEDGE_WORKER__RECONCILE_POLYMARKET_FILLS=false

# POLYEDGE_WORKER__CONSUME_POLYMARKET_USER_EVENTS：
# 启用真实 Polymarket 私有 user events websocket 消费。需要真实账户凭证。
# POLYEDGE_WORKER__CONSUME_POLYMARKET_USER_EVENTS=false

# ── 信号 ────────────────────────────────────────────────────────────────────
# POLYEDGE_WORKER__RECOMPUTE_SIGNALS：
# 启用信号重算 worker 循环。当前 signals/news 仍有未完成链路，默认关闭。
# POLYEDGE_WORKER__RECOMPUTE_SIGNALS=false

# ── Orderbook 服务地址 ──────────────────────────────────────────────────────
# POLYEDGE_ORDERBOOK__SERVICE_URL：
# Worker 访问 orderbook 服务的 HTTP 地址，用于读取盘口和注册 token。
# Docker Compose 已内置默认值 http://polyedge-orderbook:38002。
# POLYEDGE_ORDERBOOK__SERVICE_URL=http://polyedge-orderbook:38002

# ── 推荐配置示例 ────────────────────────────────────────────────────────────
# Rewards validation/live 要执行策略 tick 和撤单/重置命令，至少需要开启 rewards poll。
# live 下还需要真实 Polymarket 凭证，并把 rewards execution_mode 切到 live。
# Polymarket live / Deposit Wallet 示例见 deploy/.env.polymarket.example。
# POLYEDGE_WORKER__POLL_REWARD_BOT：
# 推荐开启 rewards 时设为 true；不运行 rewards worker 时保持 false。
# POLYEDGE_WORKER__POLL_REWARD_BOT=true
