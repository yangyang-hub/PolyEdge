# PolyEdge Orderbook 服务环境变量。
# 与 .env（公共变量）配合使用。

# POLYEDGE_ORDERBOOK__PORT：
# orderbook 服务容器内 HTTP 监听端口。Compose 健康检查默认使用 38002；一般不要改。
# POLYEDGE_ORDERBOOK__PORT=38002

# POLYEDGE_ORDERBOOK_BIND：
# orderbook 服务暴露到宿主机的监听地址。生产通常只需要内网访问，可按部署网络限制。
# POLYEDGE_ORDERBOOK_BIND=0.0.0.0

# POLYEDGE_ORDERBOOK_PORT：
# orderbook 服务暴露到宿主机的端口，映射到容器内 38002。
# POLYEDGE_ORDERBOOK_PORT=38002

# POLYEDGE_ORDERBOOK__WRITE_TOKEN：
# 内部 register/ingest/delete 写接口共享密钥。必须与 worker 的值一致；不要放入公共 .env。
POLYEDGE_ORDERBOOK__WRITE_TOKEN=change-me

# POLYEDGE_ORDERBOOK_STREAM__MAX_TOKENS：
# orderbook 服务最多订阅的 token 数量。默认 3000；过低会导致 rewards 覆盖不全，过高会增加 WS/poll 内存占用。
# POLYEDGE_ORDERBOOK_STREAM__MAX_TOKENS=3000

# POLYEDGE_ORDERBOOK_STREAM__MAX_LEVELS_PER_SIDE：
# 每个 token 在进程内缓存和 HTTP ingest 中最多保留的 bid/ask 深度档数。
# 写入时先按 bids 降序、asks 升序排序，再裁剪最优档位。默认 100；调高会增加内存占用。
# POLYEDGE_ORDERBOOK_STREAM__MAX_LEVELS_PER_SIDE=100

# POLYEDGE_ORDERBOOK_STREAM__STALE_THRESHOLD_MS：
# poll reconciler 的盘口年龄阈值。设为 0 只关闭年龄 stale 检查，TTL 过期仍会触发 reconcile。
# POLYEDGE_ORDERBOOK_STREAM__STALE_THRESHOLD_MS=15000
