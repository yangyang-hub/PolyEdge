# PolyEdge Orderbook 服务环境变量。
# 复制为 deploy/.env.orderbook。

# 可选：覆盖 orderbook 镜像 tag；未配置时 docker-compose 使用 polyedge-orderbook:local。
# POLYEDGE_ORDERBOOK_IMAGE=polyedge-orderbook:local

# 宿主机暴露地址/端口；容器内 orderbook HTTP 端口固定使用 38002。
# POLYEDGE_ORDERBOOK_BIND=0.0.0.0
# POLYEDGE_ORDERBOOK_PORT=38002

# PostgreSQL 连接字符串。orderbook 服务用于同步 markets / reward_markets。
# deploy.sh 会拒绝空值或仍包含 change-me 的占位值。
POLYEDGE_POSTGRES__URL=postgres://polyedge:change-me@host.docker.internal:5432/polyedge

# 部署环境标识。非本地环境不要使用 local。
POLYEDGE_RUNTIME__ENVIRONMENT=production

# 内部 register/ingest/delete 写接口共享密钥。
# 必须与 deploy/.env.api 中的值一致。
POLYEDGE_ORDERBOOK__WRITE_TOKEN=change-me

# 可选：订阅 token 上限。过低会导致 rewards 盘口覆盖不足，过高会增加 WS/poll 负载。
# POLYEDGE_ORDERBOOK_STREAM__MAX_TOKENS=3000

# 可选：每个 token 保留的 bid/ask 深度档数。写入时会先排序再裁剪最优档位。
# POLYEDGE_ORDERBOOK_STREAM__MAX_LEVELS_PER_SIDE=100

# 可选：poll reconciler 的盘口年龄阈值；0 只关闭年龄 stale 优先级，TTL 过期仍生效。
# POLYEDGE_ORDERBOOK_STREAM__STALE_THRESHOLD_MS=15000
