# PolyEdge Orderbook 服务环境变量。
# 复制为 deploy/.env.orderbook。
# Orderbook env 只放市场同步、盘口缓存和内部写接口配置，不放 Polymarket 私钥或 AI key。

# 可选：覆盖 orderbook 镜像 tag；未配置时 docker-compose 使用 polyedge-orderbook:local。
# POLYEDGE_ORDERBOOK_IMAGE=polyedge-orderbook:local

# 可选：orderbook 暴露到宿主机的监听地址；只影响 Docker 端口映射。
# POLYEDGE_ORDERBOOK_BIND=0.0.0.0

# 可选：orderbook 暴露到宿主机的端口；跨服务器 API 应访问该端口。
# POLYEDGE_ORDERBOOK_PORT=38002

# Orderbook 进程在容器内监听的 HTTP 端口；需与 Compose container 端口和健康检查一致。
POLYEDGE_ORDERBOOK__PORT=38002

# PostgreSQL 连接字符串。orderbook 服务用它同步 markets / reward_markets，deploy.sh 会拒绝空值或 change-me。
POLYEDGE_POSTGRES__URL=postgres://polyedge:change-me@host.docker.internal:5432/polyedge

# PostgreSQL 连接池上限；市场同步和盘口服务共享，默认 20。
POLYEDGE_POSTGRES__MAX_CONNECTIONS=20

# 部署环境标识。非本地环境不要使用 local；影响 dev bypass 校验等安全分支。
POLYEDGE_RUNTIME__ENVIRONMENT=production

# 内部 register/ingest/delete 写接口共享密钥；必须与 deploy/.env.api 中的值一致。
POLYEDGE_ORDERBOOK__WRITE_TOKEN=change-me

# 可选：仅一次性演示允许无数据库启动；生产或长期运行不要设置。
# POLYEDGE_ALLOW_IN_MEMORY_DEPLOY=1

# 可选：订阅 token 上限。过低会导致 rewards 盘口覆盖不足，过高会增加 WS/poll 负载。
# POLYEDGE_ORDERBOOK_STREAM__MAX_TOKENS=3000

# 可选：每条 Polymarket WS 连接承载的 token 数；降低可缓解高消息量下的 SDK lag 告警，但会增加 WS 连接数。
# POLYEDGE_ORDERBOOK_STREAM__WS_CHUNK_SIZE=100

# 可选：每个 token 保留的 bid/ask 深度档数。写入时会先排序再裁剪最优档位。
# POLYEDGE_ORDERBOOK_STREAM__MAX_LEVELS_PER_SIDE=100

# 可选：poll reconciler 全量恢复间隔秒数；用于修复未被 WS 发现的增量丢失。
# POLYEDGE_ORDERBOOK_STREAM__POLL_RECONCILE_INTERVAL_SECS=60

# 可选：poll reconciler 的盘口年龄阈值；0 只关闭年龄 stale 优先级，TTL 过期仍生效。
# POLYEDGE_ORDERBOOK_STREAM__STALE_THRESHOLD_MS=15000

# 可选：进程内盘口缓存 TTL，单位毫秒；默认 5 分钟。
# POLYEDGE_ORDERBOOK_STREAM__BOOK_TTL_MS=300000

# 可选：token 注册刷新间隔秒数；通常保持默认。
# POLYEDGE_ORDERBOOK_STREAM__TOKEN_REFRESH_INTERVAL_SECS=60

# 可选：orderbook WS/poll stream 异常退出后的重启间隔秒数。
# POLYEDGE_ORDERBOOK_STREAM__RESTART_INTERVAL_SECS=5

# 可选：token 集合成员变化时保持 WS 连接存活并做增量 subscribe/unsubscribe（true），
# 还是整体重建连接（false，应急回滚）。默认 true。
# POLYEDGE_ORDERBOOK_STREAM__WS_INCREMENTAL_RECONCILE=true

# 可选：增量漂移应急兜底，>0 时按该周期（秒）强制 teardown+rebuild 全部 WS 连接。
# 默认 0=关，依赖 60s poll reconciler 与 SDK 重连全量重订阅兜底。
# POLYEDGE_ORDERBOOK_STREAM__FULL_RESYNC_INTERVAL_SECS=0

# 可选：是否启用 rewards 5 分钟 K 线的 CLOB /prices-history 低频同步。
# POLYEDGE_ORDERBOOK_STREAM__REWARD_CANDLE_HISTORY_ENABLED=true

# 可选：rewards candle history 同步周期秒数；默认 300，代码会限制在 60-3600。
# POLYEDGE_ORDERBOOK_STREAM__REWARD_CANDLE_HISTORY_SYNC_INTERVAL_SECS=300

# 可选：每个 token 的 /prices-history 请求间隔毫秒；默认 500，代码会限制在 250-10000。
# POLYEDGE_ORDERBOOK_STREAM__REWARD_CANDLE_HISTORY_REQUEST_DELAY_MS=500

# 可选：每轮最多同步多少个 active reward token；0 表示不发 history 请求。
# POLYEDGE_ORDERBOOK_STREAM__REWARD_CANDLE_HISTORY_MAX_TOKENS_PER_CYCLE=600

# 可选：服务启动后首次有 active token 时回补的历史秒数；默认 2 小时。
# POLYEDGE_ORDERBOOK_STREAM__REWARD_CANDLE_HISTORY_BACKFILL_SECS=7200

# 可选：后续增量同步的历史秒数；默认 15 分钟，用于覆盖 provider 延迟和周期重叠。
# POLYEDGE_ORDERBOOK_STREAM__REWARD_CANDLE_HISTORY_INCREMENTAL_SECS=900

# 可选：Gamma full market sync 间隔秒数；orderbook 服务按至少 60 秒执行。
# POLYEDGE_WORKER__MARKET_SYNC_INTERVAL_SECS=300

# 可选：Polymarket CLOB API host；orderbook 盘口 poll 和 rewards catalog 同步使用。
# POLYEDGE_POLYMARKET__CLOB_HOST=https://clob.polymarket.com

# 可选：Polymarket market websocket host；orderbook WS stream 使用。
# POLYEDGE_POLYMARKET__WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market

# 可选：Polymarket Gamma API host；orderbook market sync 使用。
# POLYEDGE_POLYMARKET__GAMMA_HOST=https://gamma-api.polymarket.com
