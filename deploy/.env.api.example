# PolyEdge API 服务环境变量。
# 与 .env（公共变量）和 .env.worker（内嵌后台 runtime）配合使用。

# POLYEDGE_API_BIND：
# API 暴露到宿主机的监听地址。0.0.0.0 表示所有网卡可访问；只给本机反代可改为 127.0.0.1。
# POLYEDGE_API_BIND=0.0.0.0

# POLYEDGE_API_PORT：
# API 暴露到宿主机的端口，映射到容器内 38001。
# POLYEDGE_API_PORT=38001

# POLYEDGE_ORDERBOOK__SERVICE_URL：
# API 及其内嵌 worker runtime 访问 orderbook 服务的 HTTP 地址。
# 同一 Compose 项目部署时使用 Docker 服务名；不要在容器内使用 localhost。
# 跨服务器部署时改为 orderbook 服务器的实际地址（如 http://192.168.31.10:38002）。
POLYEDGE_ORDERBOOK__SERVICE_URL=http://polyedge-orderbook:38002
