# PolyEdge API + 内嵌 worker runtime 环境变量。
# 复制为 deploy/.env.api。
# 真实私钥、CLOB 凭证和 AI provider key 只应放在 API env，不要放入 Front/Orderbook env。

# ── Compose 镜像与端口映射 ───────────────────────────────────────────────
# 可选：覆盖 API 镜像 tag；未配置时 docker-compose 使用 polyedge-api:local。
# POLYEDGE_API_IMAGE=polyedge-api:local

# 可选：API 暴露到宿主机的监听地址；只影响 Docker 端口映射，不改变容器内监听地址。
# POLYEDGE_API_BIND=0.0.0.0

# 可选：API 暴露到宿主机的端口；浏览器和前端 NEXT_PUBLIC_POLYEDGE_API_BASE_URL 应指向该端口。
# POLYEDGE_API_PORT=38001

# ── API HTTP / 存储 ──────────────────────────────────────────────────────
# API 进程在容器内监听的地址；部署模板固定使用 0.0.0.0 以便 Docker 端口映射可访问。
POLYEDGE_SERVER__HOST=0.0.0.0

# API 进程在容器内监听的端口；需与 deploy/docker-compose.yml 的 container 端口和健康检查一致。
POLYEDGE_SERVER__PORT=38001

# PostgreSQL 连接字符串。生产/共享部署必须配置，deploy.sh 会拒绝空值或 change-me 占位值。
POLYEDGE_POSTGRES__URL=postgres://polyedge:change-me@host.docker.internal:5432/polyedge

# PostgreSQL 连接池上限；rewards live 持有 advisory lease，启用时至少需要 2，默认 20。
POLYEDGE_POSTGRES__MAX_CONNECTIONS=20

# 可选：Redis 连接字符串；为空时回退进程内内存实现，无法验证多进程共享状态和持久化 outbox。
# POLYEDGE_REDIS__URL=redis://host.docker.internal:6379/0

# 可选：仅一次性演示允许无数据库启动；生产或长期运行不要设置。
# POLYEDGE_ALLOW_IN_MEMORY_DEPLOY=1

# ── Runtime / 鉴权 ───────────────────────────────────────────────────────
# 部署环境标识。非本地部署使用 production；dev auth bypass 只允许 local。
POLYEDGE_RUNTIME__ENVIRONMENT=production

# 初始运行模式。当前默认 live_auto；旧 mock mode 已移除。
POLYEDGE_RUNTIME__INITIAL_MODE=live_auto

# 是否关闭 API 鉴权。内网部署模板默认 true；公网/生产化前应改为 false 并配置 JWT/step-up。
POLYEDGE_AUTH__DISABLED=true

# 可选：写操作 step-up 验证码；POLYEDGE_AUTH__DISABLED=false 时 deploy.sh 要求非占位值。
# POLYEDGE_AUTH__STEP_UP_CODE=change-me

# 可选：Ed25519 JWT 公钥数组 JSON；字段为 kid 和 public_key_base64。
# POLYEDGE_AUTH__KEYS_JSON=[{"kid":"prod","public_key_base64":"<base64-ed25519-public-key>"}]

# 可选：逗号分隔的已吊销 session id；用于强制指定会话失效。
# POLYEDGE_AUTH__REVOKED_SESSIONS=

# 可选：ISO8601 时间；早于该时间签发的 session 会被要求重新认证。
# POLYEDGE_AUTH__FORCE_REAUTH_AFTER=2026-01-01T00:00:00Z

# 可选：JWT issuer 校验值；需要与前端/签发服务保持一致。
# POLYEDGE_AUTH__ISSUER=polyedge-nextjs

# 可选：JWT audience 校验值；需要与前端/签发服务保持一致。
# POLYEDGE_AUTH__AUDIENCE=polyedge-rust-api

# 可选：JWT 时钟偏移容忍秒数。
# POLYEDGE_AUTH__CLOCK_SKEW_SECS=30

# 可选：读请求 token 最大 TTL 秒数。
# POLYEDGE_AUTH__MAX_QUERY_TTL_SECS=60

# 可选：写请求 token 最大 TTL 秒数。
# POLYEDGE_AUTH__MAX_WRITE_TTL_SECS=30

# 可选：step-up 授权窗口最大秒数。
# POLYEDGE_AUTH__MAX_STEP_UP_WINDOW_SECS=600

# ── Orderbook 服务连接 ──────────────────────────────────────────────────
# API/内嵌 worker 访问 polyedge-orderbook 的 HTTP 地址；同一 Compose 项目使用服务名。
POLYEDGE_ORDERBOOK__SERVICE_URL=http://polyedge-orderbook:38002

# Orderbook register/ingest/delete 写接口共享密钥；必须与 deploy/.env.orderbook 完全一致。
POLYEDGE_ORDERBOOK__WRITE_TOKEN=change-me

# 可选：worker 向 orderbook 注册 token 的总预算；过低会导致 rewards/订单盘口覆盖不足。
# POLYEDGE_ORDERBOOK_STREAM__MAX_TOKENS=3000

# 可选：rewards 候选市场预热订阅上限；活跃订单和 eligible 计划不受该上限影响。设为 0 可关闭候选预热。
# POLYEDGE_ORDERBOOK_STREAM__REWARD_CANDIDATE_TOKEN_CAP=50

# 可选：orderbook 服务每条 Polymarket WS 连接承载的 token 数；仅 polyedge-orderbook 读取。
# POLYEDGE_ORDERBOOK_STREAM__WS_CHUNK_SIZE=100

# 可选：worker 本地 rewards 盘口 cache 每侧保留档数；应与 orderbook 服务裁剪深度兼容。
# POLYEDGE_ORDERBOOK_STREAM__MAX_LEVELS_PER_SIDE=100

# 可选：worker 本地盘口 cache TTL，单位毫秒；默认 5 分钟。
# POLYEDGE_ORDERBOOK_STREAM__BOOK_TTL_MS=300000

# 可选：rewards 内部 WS 断线后的重连间隔秒数。
# POLYEDGE_ORDERBOOK_STREAM__RESTART_INTERVAL_SECS=5

# ── 子系统总开关 ────────────────────────────────────────────────────────
# 新闻采集总开关；同时开启 POLYEDGE_WORKER__POLL_NEWS 才会抓取 RSS/Atom。
POLYEDGE_NEWS__ENABLED=true

# 套利雷达总开关；只读发现/分析，不会创建订单。
POLYEDGE_ARBITRAGE__ENABLED=false

# Rewards live bot 总开关；同时开启 POLYEDGE_WORKER__POLL_REWARD_BOT 才会执行 live loop。
POLYEDGE_REWARDS__ENABLED=false

# Copytrade 只读跟踪/钱包分析总开关；同时开启对应 worker 才会轮询。
POLYEDGE_COPYTRADE__ENABLED=false



# ── 内嵌 worker 循环开关────────────────────────────────────────────────
# 抓取配置的 RSS/Atom 新闻源；需要 POLYEDGE_NEWS__ENABLED=true。
POLYEDGE_WORKER__POLL_NEWS=true

# 将已抓取新闻提升为 events/evidences；当前不会自动生成 signals。
POLYEDGE_WORKER__PROMOTE_NEWS_EVENTS=false

# 周期性重算 signals；仅使用数据库内数据。
POLYEDGE_WORKER__RECOMPUTE_SIGNALS=false

# 周期性扫描套利雷达；需要 POLYEDGE_ARBITRAGE__ENABLED=true。
POLYEDGE_WORKER__POLL_ARBITRAGE_RADAR=false

# 周期性分析已记录的套利机会；需要 POLYEDGE_ARBITRAGE__ENABLED=true。
POLYEDGE_WORKER__ANALYZE_ARBITRAGE_OPPORTUNITIES=false

# 启动 rewards live poll loop；需要 POLYEDGE_REWARDS__ENABLED=true、Postgres、orderbook 和真实账户配置。
POLYEDGE_WORKER__POLL_REWARD_BOT=false

# 启动 rewards 信息风险异步扫描；需要 rewards 配置启用 info_risk，并配置 AI provider key。
POLYEDGE_WORKER__POLL_REWARD_INFO_RISKS=false

# 启动 copytrade 钱包成交检测；需要 POLYEDGE_COPYTRADE__ENABLED=true。
POLYEDGE_WORKER__POLL_COPYTRADE=false

# 启动 copytrade 钱包分析任务；需要 POLYEDGE_COPYTRADE__ENABLED=true。
POLYEDGE_WORKER__ANALYZE_WALLETS=false



# 执行 execution request 队列；仅在需要 paper/Polymarket 私有执行链路时开启。
POLYEDGE_WORKER__DRAIN_EXECUTION_QUEUE=false

# 轮询 paper executor 订单状态；仅 paper 执行链路需要。
POLYEDGE_WORKER__POLL_PAPER_ORDER_STATUSES=false

# 对账 paper executor fills；仅 paper 执行链路需要。
POLYEDGE_WORKER__RECONCILE_PAPER_FILLS=false

# 轮询 Polymarket 私有订单状态；需要真实 CLOB 凭证。
POLYEDGE_WORKER__POLL_POLYMARKET_ORDER_STATUSES=false

# 对账 Polymarket 私有 fills；需要真实 CLOB/Data API 凭证。
POLYEDGE_WORKER__RECONCILE_POLYMARKET_FILLS=false

# 消费 Polymarket user websocket；需要真实 CLOB 凭证。
POLYEDGE_WORKER__CONSUME_POLYMARKET_USER_EVENTS=false

# 可选：消费 orderbook 服务内部盘口 stream；内嵌 worker runtime 已不再运行该循环，
# 盘口订阅统一由独立 polyedge-orderbook 服务负责，保留该开关仅为前端 Settings 兼容展示。
# POLYEDGE_WORKER__CONSUME_ORDERBOOK_STREAM=false

# 注：市场同步（POLYEDGE_WORKER__POLL_MARKET_SYNC）已迁移到独立 polyedge-orderbook 服务，
# 内嵌 worker runtime 不再提供该循环开关；同步间隔见下方 POLYEDGE_WORKER__MARKET_SYNC_INTERVAL_SECS。

# 可选：worker 单轮处理任务上限；影响新闻提升、对账等批量任务。
# POLYEDGE_WORKER__TASK_LIMIT=100

# 可选：新闻提升间隔秒数；仅 POLYEDGE_WORKER__PROMOTE_NEWS_EVENTS=true 时生效。
# POLYEDGE_WORKER__NEWS_PROMOTION_INTERVAL_SECS=60

# 可选：signals 重算间隔秒数；仅 POLYEDGE_WORKER__RECOMPUTE_SIGNALS=true 时生效。
# POLYEDGE_WORKER__SIGNAL_RECOMPUTE_INTERVAL_SECS=120

# 可选：套利机会分析间隔秒数；仅 POLYEDGE_WORKER__ANALYZE_ARBITRAGE_OPPORTUNITIES=true 时生效。
# POLYEDGE_WORKER__ARBITRAGE_ANALYSIS_INTERVAL_SECS=300

# 可选：execution 队列 drain 间隔秒数；仅 POLYEDGE_WORKER__DRAIN_EXECUTION_QUEUE=true 时生效。
# POLYEDGE_WORKER__EXECUTION_DRAIN_INTERVAL_SECS=5

# 可选：订单状态轮询间隔秒数；paper/Polymarket order status worker 共用。
# POLYEDGE_WORKER__ORDER_STATUS_POLL_INTERVAL_SECS=15

# 可选：成交对账轮询间隔秒数；paper/Polymarket fill reconciliation worker 共用。
# POLYEDGE_WORKER__FILL_RECONCILIATION_INTERVAL_SECS=15

# 可选：Polymarket user websocket 异常退出后的重启间隔秒数。
# POLYEDGE_WORKER__POLYMARKET_USER_EVENT_RESTART_INTERVAL_SECS=5

# 可选：orderbook token 注册和 orderbook 服务市场同步间隔秒数；orderbook 侧最低 60 秒。
# POLYEDGE_WORKER__MARKET_SYNC_INTERVAL_SECS=300

# ── Polymarket live 凭证（可选，启用私有任务或 rewards live 前必填）──────
# Polymarket 账户地址；rewards/copytrade 只读公开数据不一定需要，私有订单链路必须配置。
# POLYEDGE_POLYMARKET__ACCOUNT_ID=0xYourAccount

# 签名类型：eoa、proxy、gnosis_safe、poly_1271；已有 Deposit Wallet 使用 poly_1271。
# POLYEDGE_POLYMARKET__SIGNATURE_TYPE=poly_1271

# 资金钱包地址；Deposit Wallet 路径填 deposit wallet 地址，余额同步优先使用该地址。
# POLYEDGE_POLYMARKET__FUNDER=0xYourFunderOrDepositWallet

# 私钥。只放 API env；不要提交，不要放进 Front/Orderbook 容器环境。
# POLYEDGE_POLYMARKET__PRIVATE_KEY=0xYourPrivateKey

# CLOB API key；私有订单、成交、user websocket 和 rewards live 需要。
# POLYEDGE_POLYMARKET__API_KEY=replace-with-clob-api-key

# CLOB API secret；私有订单、成交、user websocket 和 rewards live 需要。
# POLYEDGE_POLYMARKET__API_SECRET=replace-with-clob-api-secret

# CLOB API passphrase；私有订单、成交、user websocket 和 rewards live 需要。
# POLYEDGE_POLYMARKET__API_PASSPHRASE=replace-with-clob-api-passphrase

# Polygon RPC URL；worker 用于读取资金钱包链上 pUSD 余额作为 CLOB balance 回退。
# POLYEDGE_POLYMARKET__POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# 可选：Polymarket chain id；Polygon 主网为 137。
# POLYEDGE_POLYMARKET__CHAIN_ID=137

# 可选：CLOB HTTP API host；通常保持默认。
# POLYEDGE_POLYMARKET__CLOB_HOST=https://clob.polymarket.com

# 可选：CLOB market websocket host；通常保持默认。
# POLYEDGE_POLYMARKET__WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market

# 可选：Gamma API host；orderbook 市场同步和 API 只读路径使用数据库，不在请求时直连。
# POLYEDGE_POLYMARKET__GAMMA_HOST=https://gamma-api.polymarket.com

# 可选：Data API host；copytrade 和成交/持仓回退会使用。
# POLYEDGE_POLYMARKET__DATA_API_HOST=https://data-api.polymarket.com

# 可选：单轮订单状态查询上限。
# POLYEDGE_POLYMARKET__ORDER_STATUS_POLL_LIMIT=100

# 可选：单轮成交查询上限。
# POLYEDGE_POLYMARKET__FILL_POLL_LIMIT=100

# 可选：Polymarket market websocket 单连接订阅上限。
# POLYEDGE_POLYMARKET__WS_MAX_INSTRUMENTS=100

# 可选：Polymarket user websocket 空闲告警秒数。
# POLYEDGE_POLYMARKET__WS_IDLE_WARN_SECS=15

# 可选：Polymarket user websocket 判定 stale 的秒数。
# POLYEDGE_POLYMARKET__WS_STALE_AFTER_SECS=60

# ── Rewards AI / 信息风险 provider（可选）───────────────────────────────
# OpenAI API key；AI advisory 或信息风险使用 OpenAI provider 时配置。
# POLYEDGE_REWARDS__AI_OPENAI_API_KEY=replace-with-openai-api-key

# Anthropic API key；AI advisory 或信息风险使用 Anthropic provider 时配置。
# POLYEDGE_REWARDS__AI_ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# 可选：OpenAI API base URL；兼容代理时可覆盖。
# POLYEDGE_REWARDS__AI_OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：Anthropic API base URL；兼容代理时可覆盖。
# POLYEDGE_REWARDS__AI_ANTHROPIC_BASE_URL=https://api.anthropic.com

# 可选：AI advisory / 信息风险默认模型名；具体 provider/request format 由 rewards 配置控制。
# POLYEDGE_REWARDS__AI_MODEL=gpt-4.1-mini

# 可选：AI advisory 最低置信度，bps；6500 表示 0.65。
# POLYEDGE_REWARDS__AI_MIN_CONFIDENCE_BPS=6500

# 可选：AI provider 单次请求超时秒数。
# POLYEDGE_REWARDS__AI_REQUEST_TIMEOUT_SECS=180

# 可选：AI advisory orderbook 事件驱动批量通道（默认关闭）。开启后盘口首次就绪的市场
# 会攒批单次 provider 调用评估，与 full-tick provider refresh 并存；详见 AGENTS.md。
# POLYEDGE_REWARDS__AI_ADVISORY_EVENT_DRIVEN_ENABLED=false
# 可选：批量评估一次最多打包的市场数（默认 8，clamp [1,12]）。
# POLYEDGE_REWARDS__AI_ADVISORY_BATCH_SIZE=8
# 可选：攒批等待超时秒数（默认 8）。
# POLYEDGE_REWARDS__AI_ADVISORY_BATCH_TIMEOUT_SECS=8

# 可选：信息风险异步扫描间隔秒数；worker 内部最低 30 秒。
# POLYEDGE_REWARDS__INFO_RISK_INTERVAL_SECS=300

# 可选：AI advisory / 信息风险 provider 每轮最多处理的 condition 数；默认 50，0 表示本轮不发 provider 请求。
# POLYEDGE_REWARDS__INFO_RISK_MAX_MARKETS_PER_CYCLE=50

# 可选：信息风险最低置信度，bps；7000 表示 0.70。
# POLYEDGE_REWARDS__INFO_RISK_MIN_CONFIDENCE_BPS=7000

# 可选：OpenAI Responses 信息风险是否启用 web search tool；默认 false。
# POLYEDGE_REWARDS__INFO_RISK_WEB_SEARCH_ENABLED=false

# ── 业务调参（可选，通常优先用前端 Settings/runtime_config）──────────────

# ── 风控阈值（执行链路强制生效；前端 Settings/runtime_config 可调）─────────
# 可选：风险敞口比率的参考 NAV 基数（美元）；gross/net 敞口比率按此换算为敞口美元。
# POLYEDGE_RISK__EXPOSURE_REFERENCE_NAV=100.00

# 可选：单日累计最大亏损（美元）；当日亏损触及该值会触发 kill switch 熔断。
# POLYEDGE_RISK__MAX_DAILY_LOSS=5000.00

# 可选：最大总敞口比率，相对 exposure_reference_nav；0.50 表示不超过参考 NAV 的 50%。
# POLYEDGE_RISK__MAX_GROSS_EXPOSURE=0.50

# 可选：最大净敞口比率，相对 exposure_reference_nav；0.30 表示不超过参考 NAV 的 30%。
# POLYEDGE_RISK__MAX_NET_EXPOSURE=0.30

# 可选：signal 最低置信度（0..1）；低于该值的 signal 不采纳。
# POLYEDGE_RISK__MIN_SIGNAL_CONFIDENCE=0.55

# 可选：执行所需最低边际（0..1）。
# POLYEDGE_RISK__MIN_EDGE_TO_EXECUTE=0.03

# 可选：同时开放的最大风控告警数。
# POLYEDGE_RISK__MAX_OPEN_ALERTS=3

# 可选：rewards live 兜底 poll 间隔秒数；event-driven fast reconcile 仍会更快触发。
# POLYEDGE_REWARDS__POLL_INTERVAL_SECS=60

# 可选：新闻轮询间隔秒数；仅新闻 worker 启用时生效。
# POLYEDGE_NEWS__POLL_INTERVAL_SECS=60

# 可选：单个新闻源请求超时秒数。
# POLYEDGE_NEWS__REQUEST_TIMEOUT_SECS=10

# 可选：每个新闻源单轮最多读取 item/entry 数。
# POLYEDGE_NEWS__MAX_ITEMS_PER_SOURCE=50

# 新闻源 JSON；部署模板显式写入当前默认 RSS/Atom 源列表，设置后会覆盖代码内置默认。
POLYEDGE_NEWS__SOURCES_JSON=[{"id":"fed_press","source_type":"official","url":"https://www.federalreserve.gov/feeds/press_all.xml","reliability":"0.98","enabled":true},{"id":"sec_press","source_type":"official","url":"https://www.sec.gov/news/pressreleases.rss","reliability":"0.96","enabled":true},{"id":"nasa_news","source_type":"official","url":"https://www.nasa.gov/news-release/feed/","reliability":"0.95","enabled":true},{"id":"bbc_world","source_type":"news","url":"https://feeds.bbci.co.uk/news/world/rss.xml","reliability":"0.85","enabled":true},{"id":"npr_news","source_type":"news","url":"https://feeds.npr.org/1001/rss.xml","reliability":"0.84","enabled":true},{"id":"coindesk","source_type":"news","url":"https://www.coindesk.com/arc/outboundfeeds/rss","reliability":"0.80","enabled":true},{"id":"cointelegraph","source_type":"news","url":"https://cointelegraph.com/rss","reliability":"0.74","enabled":true},{"id":"decrypt","source_type":"news","url":"https://decrypt.co/feed","reliability":"0.74","enabled":true}]

# 可选：copytrade 钱包轮询间隔秒数。
# POLYEDGE_COPYTRADE__POLL_INTERVAL_SECS=60

# 可选：copytrade 钱包分析间隔秒数。
# POLYEDGE_COPYTRADE__ANALYSIS_INTERVAL_SECS=300

# 可选：每个 tracked wallet 单轮读取的 Data API 活动条数。
# POLYEDGE_COPYTRADE__WALLET_ACTIVITY_LIMIT=50

# 可选：套利雷达轮询间隔秒数。
# POLYEDGE_ARBITRAGE__POLL_INTERVAL_SECS=5

# 可选：套利雷达单轮扫描市场数。
# POLYEDGE_ARBITRAGE__SCAN_LIMIT=100

# 可选：套利盘口来源；当前部署建议使用 market_snapshot。
# POLYEDGE_ARBITRAGE__BOOK_SOURCE=market_snapshot

# 可选：扫描器版本标识；写入套利机会元数据，用于区分算法版本。
# POLYEDGE_ARBITRAGE__SCANNER_VERSION=v1

# 可选：机会分析回溯窗口（小时）。
# POLYEDGE_ARBITRAGE__ANALYSIS_LOOKBACK_HOURS=24

# 可选：盘口最大年龄（毫秒）；超过该年龄的盘口判定过期并跳过。
# POLYEDGE_ARBITRAGE__MAX_BOOK_AGE_MS=10000

# 可选：套利机会存活时间（秒）；超时后不再视为同一机会。
# POLYEDGE_ARBITRAGE__OPPORTUNITY_TTL_SECS=60

# 可选：套利事件保留时长（小时）；超期记录会被清理。
# POLYEDGE_ARBITRAGE__EVENT_RETENTION_HOURS=24

# 可选：最低总边际（0.005 表示 0.5%）；总边际低于该值的机会被过滤。
# POLYEDGE_ARBITRAGE__MIN_GROSS_EDGE=0.005

# 可选：最低可成交容量（shares）；容量低于该值的机会被过滤。
# POLYEDGE_ARBITRAGE__MIN_CAPACITY=1

# 可选：手续费缓冲（0.005 表示 0.5%）；从总边际中扣除得到净边际。
# POLYEDGE_ARBITRAGE__FEE_BUFFER=0.005

# 可选：滑点缓冲（0.005 表示 0.5%）；从总边际中扣除得到净边际。
