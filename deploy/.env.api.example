# PolyEdge API + 内嵌 worker runtime 环境变量。
# 复制为 deploy/.env.api。不要提交真实密钥。

# ── 服务与存储 ────────────────────────────────────────────────────────────
# 可选：覆盖 API 镜像 tag；未配置时 docker-compose 使用 polyedge-api:local。
# POLYEDGE_API_IMAGE=polyedge-api:local

# API 暴露到宿主机的监听地址和端口，映射到容器内 38001。
# POLYEDGE_API_BIND=0.0.0.0
# POLYEDGE_API_PORT=38001

# PostgreSQL 连接字符串。API 和内嵌 worker runtime 共用。
# deploy.sh 会拒绝空值或仍包含 change-me 的占位值。
POLYEDGE_POSTGRES__URL=postgres://polyedge:change-me@host.docker.internal:5432/polyedge

# 部署环境标识。非本地环境不要使用 local，避免误开 dev-auth 绕过。
POLYEDGE_RUNTIME__ENVIRONMENT=production

# 纯内网部署可设为 true，API 会跳过 console/connector/mode 鉴权。
# 公网或生产级多用户环境必须改为 false，并接入真实 session/JWT。
POLYEDGE_AUTH__DISABLED=true

# 仅当 POLYEDGE_AUTH__DISABLED=false 时需要。
# POLYEDGE_AUTH__STEP_UP_CODE=change-me
# POLYEDGE_AUTH__KEYS_JSON=[{"kid":"prod","public_key_base64":"<base64-ed25519-public-key>"}]

# ── Orderbook 连接 ────────────────────────────────────────────────────────
# API 及内嵌 worker 访问 orderbook 服务的 HTTP 地址。
# 同一 Compose 项目使用服务名；跨服务器改为实际地址。
POLYEDGE_ORDERBOOK__SERVICE_URL=http://polyedge-orderbook:38002

# 内嵌 worker 注册 orderbook token 时使用的共享密钥。
# 必须与 deploy/.env.orderbook 中的值一致。
POLYEDGE_ORDERBOOK__WRITE_TOKEN=change-me

# ── 业务子系统总开关 ──────────────────────────────────────────────────────
POLYEDGE_NEWS__ENABLED=false
POLYEDGE_ARBITRAGE__ENABLED=false
POLYEDGE_REWARDS__ENABLED=false
POLYEDGE_COPYTRADE__ENABLED=false

# ── 后台循环开关（默认全部关闭）───────────────────────────────────────────
POLYEDGE_WORKER__POLL_NEWS=false
POLYEDGE_WORKER__PROMOTE_NEWS_EVENTS=false
POLYEDGE_WORKER__RECOMPUTE_SIGNALS=false

POLYEDGE_WORKER__POLL_ARBITRAGE_RADAR=false
POLYEDGE_WORKER__ANALYZE_ARBITRAGE_OPPORTUNITIES=false

POLYEDGE_WORKER__POLL_REWARD_BOT=false
POLYEDGE_WORKER__POLL_REWARD_INFO_RISKS=false

POLYEDGE_WORKER__POLL_COPYTRADE=false
POLYEDGE_WORKER__ANALYZE_WALLETS=false

# 通用 execution/paper/live 对账任务当前不是 rewards live 的必需路径。
# 只有确认对应 pipeline 和真实凭证后再开启。
POLYEDGE_WORKER__DRAIN_EXECUTION_QUEUE=false
POLYEDGE_WORKER__POLL_PAPER_ORDER_STATUSES=false
POLYEDGE_WORKER__RECONCILE_PAPER_FILLS=false
POLYEDGE_WORKER__POLL_POLYMARKET_ORDER_STATUSES=false
POLYEDGE_WORKER__RECONCILE_POLYMARKET_FILLS=false
POLYEDGE_WORKER__CONSUME_POLYMARKET_USER_EVENTS=false

# ── Polymarket live 凭证（可选）────────────────────────────────────────────
# 按账户类型复制一组到本文件；首次实盘请先用小额账户验证。
# CLOB/Gamma/Data API host、poll limit 等已有代码默认值，通常不需要配置。

# 公共 CLOB L2 API 凭证；如果配置，key/secret/passphrase 必须三项一起配置。
# POLYEDGE_POLYMARKET__API_KEY=replace-with-clob-api-key
# POLYEDGE_POLYMARKET__API_SECRET=replace-with-clob-api-secret
# POLYEDGE_POLYMARKET__API_PASSPHRASE=replace-with-clob-api-passphrase

# 可选：生产建议替换为自有或有 SLA 的 Polygon RPC，用于 rewards 账户 pUSD 链上余额回填。
# POLYEDGE_POLYMARKET__POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# EOA 直接交易：
# POLYEDGE_POLYMARKET__ACCOUNT_ID=0xYourEoaAddress
# POLYEDGE_POLYMARKET__SIGNATURE_TYPE=eoa
# POLYEDGE_POLYMARKET__PRIVATE_KEY=0xYourEoaPrivateKey

# Proxy / Gnosis Safe：
# POLYEDGE_POLYMARKET__ACCOUNT_ID=0xYourProxyOrSafeAddress
# POLYEDGE_POLYMARKET__SIGNATURE_TYPE=proxy
# POLYEDGE_POLYMARKET__SIGNATURE_TYPE=gnosis_safe
# POLYEDGE_POLYMARKET__FUNDER=0xYourProxyOrSafeAddress
# POLYEDGE_POLYMARKET__PRIVATE_KEY=0xOwnerOrSignerPrivateKey

# Deposit Wallet / poly_1271：
# 适用于已部署、已入金 pUSD、已完成 approval 的 Deposit Wallet。
# 当前系统不负责 relayer wallet-create、pUSD 入金/包装或 approval 批处理。
# POLYEDGE_POLYMARKET__ACCOUNT_ID=0xYourDepositWalletAddress
# POLYEDGE_POLYMARKET__SIGNATURE_TYPE=poly_1271
# POLYEDGE_POLYMARKET__FUNDER=0xYourDepositWalletAddress
# POLYEDGE_POLYMARKET__PRIVATE_KEY=0xOwnerOrSessionSignerPrivateKey

# Rewards live 最小启用组合：
# POLYEDGE_REWARDS__ENABLED=true
# POLYEDGE_WORKER__POLL_REWARD_BOT=true

# ── Rewards AI / 信息风险 provider（可选）────────────────────────────────
# 前端只保存 provider/request format/TTL；API key、base URL、模型名只放 API/worker 环境。
# POLYEDGE_REWARDS__AI_OPENAI_API_KEY=replace-with-openai-api-key
# POLYEDGE_REWARDS__AI_ANTHROPIC_API_KEY=replace-with-anthropic-api-key
# POLYEDGE_REWARDS__AI_MODEL=gpt-4.1-mini
# POLYEDGE_REWARDS__AI_OPENAI_BASE_URL=https://api.openai.com/v1
# POLYEDGE_REWARDS__AI_ANTHROPIC_BASE_URL=https://api.anthropic.com
# POLYEDGE_REWARDS__AI_MIN_CONFIDENCE_BPS=6500
# POLYEDGE_REWARDS__INFO_RISK_MIN_CONFIDENCE_BPS=7000
# POLYEDGE_REWARDS__INFO_RISK_WEB_SEARCH_ENABLED=false

# ── 新闻源（可选）─────────────────────────────────────────────────────────
# POLYEDGE_NEWS__SOURCES_JSON=[{"id":"example","source_type":"official","url":"https://example.com/feed.xml","reliability":"0.95","enabled":true}]
