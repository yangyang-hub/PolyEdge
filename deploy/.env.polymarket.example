# PolyEdge Polymarket live / rewards live 配置示例。
# 使用方式：
# 1. 按账户类型选择下面其中一组签名配置，复制到 deploy/.env.worker。
# 2. Rewards 仅支持 live，配置中已没有 execution_mode。
# 3. 私钥只放 deploy/.env.worker；该文件现在由 API 容器内嵌的执行 runtime 加载。
# 4. HTTP handler 不直接请求 Polymarket，外部同步仍只在后台 runtime 中执行。
# 5. 首次实盘请使用很小的 quote_size_usd / max_open_orders / max_markets。

# ── 公共 CLOB V2 配置 ─────────────────────────────────────────────────────
# POLYEDGE_POLYMARKET__CHAIN_ID：
# Polymarket 所在链 ID。生产 CLOB 使用 Polygon mainnet，固定为 137。
POLYEDGE_POLYMARKET__CHAIN_ID=137

# POLYEDGE_POLYMARKET__CLOB_HOST：
# Polymarket CLOB REST API 地址，用于下单、撤单、订单状态和余额/allowance 更新。
POLYEDGE_POLYMARKET__CLOB_HOST=https://clob.polymarket.com

# POLYEDGE_POLYMARKET__WS_HOST：
# Polymarket CLOB 市场 websocket 地址，用于公共 orderbook 订阅。
POLYEDGE_POLYMARKET__WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market

# POLYEDGE_POLYMARKET__GAMMA_HOST：
# Polymarket Gamma API 地址，用于市场元数据同步。
POLYEDGE_POLYMARKET__GAMMA_HOST=https://gamma-api.polymarket.com

# POLYEDGE_POLYMARKET__DATA_API_HOST：
# Polymarket Data API 地址，用于钱包成交、跟单和历史成交类数据。
POLYEDGE_POLYMARKET__DATA_API_HOST=https://data-api.polymarket.com

# POLYEDGE_POLYMARKET__POLYGON_RPC_URL：
# Polygon JSON-RPC 地址。Rewards worker 用它读取资金钱包的链上 pUSD 余额；
# 当 CLOB balance-allowance 返回 0 或失败时，账户 snapshot 会使用该链上余额回填。
# 生产环境建议替换为自有或有 SLA 的 RPC。
POLYEDGE_POLYMARKET__POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# POLYEDGE_POLYMARKET__ORDER_STATUS_POLL_LIMIT：
# 每次真实订单状态轮询最多拉取/处理的订单数量。
POLYEDGE_POLYMARKET__ORDER_STATUS_POLL_LIMIT=200

# POLYEDGE_POLYMARKET__FILL_POLL_LIMIT：
# 每次真实成交对账最多拉取/处理的 fill 数量。
POLYEDGE_POLYMARKET__FILL_POLL_LIMIT=200

# POLYEDGE_POLYMARKET__WS_MAX_INSTRUMENTS：
# 单个 Polymarket market websocket 连接最多订阅的 token/instrument 数量。
POLYEDGE_POLYMARKET__WS_MAX_INSTRUMENTS=200

# POLYEDGE_POLYMARKET__WS_IDLE_WARN_SECS：
# websocket 多久没有收到消息后记录 idle 警告，单位秒。
POLYEDGE_POLYMARKET__WS_IDLE_WARN_SECS=15

# POLYEDGE_POLYMARKET__WS_STALE_AFTER_SECS：
# websocket 多久没有更新后视为 stale，单位秒；用于触发重连或保护逻辑。
POLYEDGE_POLYMARKET__WS_STALE_AFTER_SECS=60

# POLYEDGE_POLYMARKET__API_KEY：
# CLOB L2 API key。若配置 API 凭证，key/secret/passphrase 三项必须一起配置。
# POLYEDGE_POLYMARKET__API_KEY=replace-with-clob-api-key

# POLYEDGE_POLYMARKET__API_SECRET：
# CLOB L2 API secret。属于敏感信息，不要提交到仓库。
# POLYEDGE_POLYMARKET__API_SECRET=replace-with-clob-api-secret

# POLYEDGE_POLYMARKET__API_PASSPHRASE：
# CLOB L2 API passphrase。属于敏感信息，不要提交到仓库。
# POLYEDGE_POLYMARKET__API_PASSPHRASE=replace-with-clob-api-passphrase

# ── 账户类型 A：EOA 直接交易 ────────────────────────────────────────────────
# POLYEDGE_POLYMARKET__ACCOUNT_ID：
# 本地记录用的账户地址。EOA 直接交易时通常填 EOA 地址。
# POLYEDGE_POLYMARKET__ACCOUNT_ID=0xYourEoaAddress

# POLYEDGE_POLYMARKET__SIGNATURE_TYPE：
# CLOB 签名类型。EOA 直接交易使用 eoa。
# POLYEDGE_POLYMARKET__SIGNATURE_TYPE=eoa

# POLYEDGE_POLYMARKET__FUNDER：
# 订单资金地址。EOA 直接交易通常留空，表示由 signer 自身作为资金账户。
# POLYEDGE_POLYMARKET__FUNDER=

# POLYEDGE_POLYMARKET__PRIVATE_KEY：
# EOA signer 私钥。推荐只放在 worker 环境，绝不要提交到仓库。
# POLYEDGE_POLYMARKET__PRIVATE_KEY=0xYourEoaPrivateKey

# ── 账户类型 B：Proxy / Gnosis Safe ────────────────────────────────────────
# ACCOUNT_ID 建议记录实际交易/资金账户地址；FUNDER 配 proxy 或 safe 地址。
# POLYEDGE_POLYMARKET__ACCOUNT_ID：
# 本地记录用的账户地址。Proxy/Gnosis Safe 模式通常填 proxy 或 safe 地址。
# POLYEDGE_POLYMARKET__ACCOUNT_ID=0xYourProxyOrSafeAddress

# POLYEDGE_POLYMARKET__SIGNATURE_TYPE：
# CLOB 签名类型。Proxy 钱包选择 proxy；Gnosis Safe 选择 gnosis_safe，二选一。
# POLYEDGE_POLYMARKET__SIGNATURE_TYPE=proxy
# POLYEDGE_POLYMARKET__SIGNATURE_TYPE=gnosis_safe

# POLYEDGE_POLYMARKET__FUNDER：
# 实际提供资金/持仓的 proxy 或 safe 地址。
# POLYEDGE_POLYMARKET__FUNDER=0xYourProxyOrSafeAddress

# POLYEDGE_POLYMARKET__PRIVATE_KEY：
# proxy/safe 授权 owner 或 signer 私钥。推荐只放在 worker 环境，绝不要提交到仓库。
# POLYEDGE_POLYMARKET__PRIVATE_KEY=0xOwnerOrSignerPrivateKey

# ── 账户类型 C：Deposit Wallet / POLY_1271 ────────────────────────────────
# 适用于已经部署、已转入 pUSD、已从 deposit wallet 完成 approval 的钱包。
# 当前系统不负责 relayer WALLET-CREATE、pUSD 入金/包装或 approval 批处理。
# 下单前 connector 会调用 CLOB balance-allowance/update。
# POLYEDGE_POLYMARKET__ACCOUNT_ID：
# 本地记录用的账户地址。Deposit Wallet 模式填 deposit wallet 地址。
# POLYEDGE_POLYMARKET__ACCOUNT_ID=0xYourDepositWalletAddress

# POLYEDGE_POLYMARKET__SIGNATURE_TYPE：
# Deposit Wallet 使用 poly_1271，对应 Polymarket 官方 POLY_1271 / signature type 3。
# POLYEDGE_POLYMARKET__SIGNATURE_TYPE=poly_1271

# POLYEDGE_POLYMARKET__FUNDER：
# 实际提供 pUSD/持仓的 deposit wallet 地址。Deposit Wallet 模式必须配置。
# POLYEDGE_POLYMARKET__FUNDER=0xYourDepositWalletAddress

# POLYEDGE_POLYMARKET__PRIVATE_KEY：
# Deposit Wallet 的 owner 或 session signer 私钥。推荐只放在 worker 环境，绝不要提交到仓库。
# POLYEDGE_POLYMARKET__PRIVATE_KEY=0xOwnerOrSessionSignerPrivateKey

# ── Rewards live worker 开关 ───────────────────────────────────────────────
# 这些通常放 deploy/.env.worker。
# POLYEDGE_REWARDS__ENABLED：
# rewards bot 总开关。要让 worker 执行 rewards 策略，必须和 POLL_REWARD_BOT 一起开启。
# POLYEDGE_REWARDS__ENABLED=true

# POLYEDGE_WORKER__POLL_REWARD_BOT：
# rewards worker 循环开关。开启后 worker 会领取 Run/Cancel/Reset 命令并执行策略 tick。
# POLYEDGE_WORKER__POLL_REWARD_BOT=true

# ── Rewards AI advisory（可选）────────────────────────────────────────────
# 前端只保存 provider/request format/TTL；模型名、base URL 和 API key 只从 worker 环境读取。
# 开启前还需在 /rewards 配置中启用 ai_advisory_enabled。

# POLYEDGE_REWARDS__AI_OPENAI_API_KEY：
# OpenAI / OpenAI-compatible provider API key。敏感信息，只放 deploy/.env.worker。
# POLYEDGE_REWARDS__AI_OPENAI_API_KEY=replace-with-openai-api-key

# POLYEDGE_REWARDS__AI_ANTHROPIC_API_KEY：
# Anthropic Messages API key。敏感信息，只放 deploy/.env.worker。
# POLYEDGE_REWARDS__AI_ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# POLYEDGE_REWARDS__AI_OPENAI_BASE_URL：
# OpenAI 兼容接口 base URL。默认 https://api.openai.com/v1。
# POLYEDGE_REWARDS__AI_OPENAI_BASE_URL=https://api.openai.com/v1

# POLYEDGE_REWARDS__AI_ANTHROPIC_BASE_URL：
# Anthropic API base URL。默认 https://api.anthropic.com。
# POLYEDGE_REWARDS__AI_ANTHROPIC_BASE_URL=https://api.anthropic.com

# POLYEDGE_REWARDS__AI_MODEL：
# Rewards AI advisory 模型名。OpenAI 默认 gpt-4.1-mini；Anthropic provider 时改为对应模型。
# POLYEDGE_REWARDS__AI_MODEL=gpt-4.1-mini

# POLYEDGE_REWARDS__AI_MIN_CONFIDENCE_BPS：
# AI 建议被 enforce 前的最低置信度，单位 bps；6500 表示 65%。默认 6500。
# POLYEDGE_REWARDS__AI_MIN_CONFIDENCE_BPS=6500

# POLYEDGE_REWARDS__AI_REQUEST_TIMEOUT_SECS：
# 单次 AI advisory 请求超时秒数。默认 20；失败只记录告警并保留确定性计划。
# POLYEDGE_REWARDS__AI_REQUEST_TIMEOUT_SECS=20

# POLYEDGE_REWARDS__AI_MAX_MARKETS_PER_CYCLE：
# 每个 rewards full tick 最多请求 AI 判断的市场数。默认 12。
# POLYEDGE_REWARDS__AI_MAX_MARKETS_PER_CYCLE=12

# 私有订单/成交/用户事件对账任务主要服务 execution pipeline；rewards live 在 rewards worker
# 内同步本系统托管订单成交。所有 live 任务开启前请先用小额账户验证。
# POLYEDGE_WORKER__POLL_POLYMARKET_ORDER_STATUSES：
# 启用真实 Polymarket 订单状态轮询。需要 CLOB API 凭证。
# POLYEDGE_WORKER__POLL_POLYMARKET_ORDER_STATUSES=true

# POLYEDGE_WORKER__RECONCILE_POLYMARKET_FILLS：
# 启用真实 Polymarket 成交对账。用于同步 fills 到本地状态。
# POLYEDGE_WORKER__RECONCILE_POLYMARKET_FILLS=true

# POLYEDGE_WORKER__CONSUME_POLYMARKET_USER_EVENTS：
# 启用真实 Polymarket 私有 user events websocket。需要真实账户凭证。
# POLYEDGE_WORKER__CONSUME_POLYMARKET_USER_EVENTS=true
