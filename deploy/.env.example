# PolyEdge 公共环境变量。
# 部署前复制为 deploy/.env，并替换占位值。不要提交真实密钥。
#
# 各服务的专属配置见 .env.api、.env.orderbook、.env.worker、.env.front。
# 后端运行参数已有代码默认值，首次启动后会写入 PostgreSQL runtime_config 表。

# ── 数据库 ──────────────────────────────────────────────────────────────────
# API、Worker、Orderbook 共用。除非显式设置 POLYEDGE_ALLOW_IN_MEMORY_DEPLOY=1，
# 部署脚本会拒绝空值或占位值。
POLYEDGE_POSTGRES__URL=postgres://polyedge:change-me@host.docker.internal:5432/polyedge

# 可选：Redis 只有配置后才会使用。
# POLYEDGE_REDIS__URL=redis://host.docker.internal:6379

# ── 认证 ────────────────────────────────────────────────────────────────────
# 受保护控制台操作所需。API 和 Front 共用。部署时必须改成专用值。
POLYEDGE_CONSOLE_STEP_UP_CODE=change-me

# ── 部署脚本 ────────────────────────────────────────────────────────────────
# 可选：Docker 镜像名。
# POLYEDGE_API_IMAGE=polyedge-api:local
# POLYEDGE_FRONT_IMAGE=polyedge-front:local

# 可选：部署脚本保护。默认会加 /tmp/polyedge-deploy.lock 防止 cron 重叠，
# 并把 Docker Compose 构建并发限制为 1，降低小服务器磁盘 I/O 峰值。
# POLYEDGE_DEPLOY_LOCK_FILE=/tmp/polyedge-deploy.lock
# COMPOSE_PARALLEL_LIMIT=1
