# Docker publish settings. The API is bound to localhost by default because
# the frontend container reaches it through the Docker network.
POLYEDGE_FRONT_BIND=0.0.0.0
POLYEDGE_FRONT_PORT=3000
POLYEDGE_API_BIND=127.0.0.1
POLYEDGE_API_PORT=8080

# Frontend -> backend URL as seen from inside the frontend container.
POLYEDGE_API_BASE_URL=http://polyedge-api:8080
POLYEDGE_ENABLE_LIVE_SSE=1
POLYEDGE_CONSOLE_AUTH=mock-session
POLYEDGE_CONSOLE_STEP_UP_CODE=change-me

# Current codebase supports live API with local dev-auth only when backend
# runtime environment is local and POLYEDGE_AUTH__KEYS_JSON is empty.
# Treat this as prototype/shared-server mode, not production-grade auth.
POLYEDGE_INTERNAL_AUTH_DEV_BYPASS=1
POLYEDGE_INTERNAL_AUTH_KID=
POLYEDGE_INTERNAL_AUTH_PRIVATE_KEY=

# Backend bind/config.
POLYEDGE_SERVER__HOST=0.0.0.0
POLYEDGE_SERVER__PORT=8080
POLYEDGE_RUNTIME__ENVIRONMENT=local
POLYEDGE_RUNTIME__INITIAL_MODE=manual_confirm

# External infrastructure. Replace these with your existing PostgreSQL/Redis.
# If they run on the Docker host, host.docker.internal is enabled by compose.
POLYEDGE_POSTGRES__URL=postgres://polyedge:change-me@host.docker.internal:5432/polyedge
POLYEDGE_REDIS__URL=redis://host.docker.internal:6379

# Risk defaults.
POLYEDGE_RISK__EXPOSURE_REFERENCE_NAV=100.00
POLYEDGE_RISK__INITIAL_DAILY_PNL=0.00
POLYEDGE_RISK__INITIAL_GROSS_EXPOSURE=0
POLYEDGE_RISK__INITIAL_NET_EXPOSURE=0
POLYEDGE_RISK__INITIAL_OPEN_ALERTS=0
POLYEDGE_RISK__INITIAL_KILL_SWITCH=false
POLYEDGE_RISK__MIN_SIGNAL_CONFIDENCE=0.55
POLYEDGE_RISK__MIN_EDGE_TO_EXECUTE=0.03
POLYEDGE_RISK__MAX_OPEN_ALERTS=3
POLYEDGE_RISK__MAX_DAILY_LOSS=5000.00
POLYEDGE_RISK__MAX_GROSS_EXPOSURE=0.50
POLYEDGE_RISK__MAX_NET_EXPOSURE=0.30

# Polymarket defaults. Keep mock unless you have live credentials and have
# completed a separate small-funds runbook.
POLYEDGE_POLYMARKET__MODE=mock
POLYEDGE_POLYMARKET__ACCOUNT_ID=polymarket_account
POLYEDGE_POLYMARKET__CHAIN_ID=137
POLYEDGE_POLYMARKET__SIGNATURE_TYPE=eoa
POLYEDGE_POLYMARKET__FUNDER=
POLYEDGE_POLYMARKET__PRIVATE_KEY=
POLYEDGE_POLYMARKET__API_KEY=
POLYEDGE_POLYMARKET__API_SECRET=
POLYEDGE_POLYMARKET__API_PASSPHRASE=
POLYEDGE_POLYMARKET__CLOB_HOST=https://clob.polymarket.com
POLYEDGE_POLYMARKET__WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYEDGE_POLYMARKET__GAMMA_HOST=https://gamma-api.polymarket.com
POLYEDGE_POLYMARKET__DATA_API_HOST=https://data-api.polymarket.com
POLYEDGE_POLYMARKET__ORDER_STATUS_POLL_LIMIT=100
POLYEDGE_POLYMARKET__FILL_POLL_LIMIT=100
POLYEDGE_POLYMARKET__WS_MAX_INSTRUMENTS=100
POLYEDGE_POLYMARKET__WS_IDLE_WARN_SECS=15
POLYEDGE_POLYMARKET__WS_STALE_AFTER_SECS=60

# News ingestion.
POLYEDGE_NEWS__ENABLED=false
POLYEDGE_NEWS__POLL_INTERVAL_SECS=60
POLYEDGE_NEWS__REQUEST_TIMEOUT_SECS=10
POLYEDGE_NEWS__MAX_ITEMS_PER_SOURCE=50
POLYEDGE_NEWS__SOURCES_JSON=[]

# Backend internal auth verifier. Leave [] only with local dev-auth mode.
POLYEDGE_AUTH__ISSUER=polyedge-nextjs
POLYEDGE_AUTH__AUDIENCE=polyedge-rust-api
POLYEDGE_AUTH__CLOCK_SKEW_SECS=30
POLYEDGE_AUTH__MAX_QUERY_TTL_SECS=60
POLYEDGE_AUTH__MAX_WRITE_TTL_SECS=30
POLYEDGE_AUTH__MAX_STEP_UP_WINDOW_SECS=600
POLYEDGE_AUTH__REVOKED_SESSIONS=
POLYEDGE_AUTH__FORCE_REAUTH_AFTER=2026-01-01T00:00:00Z
POLYEDGE_AUTH__KEYS_JSON=[]
