# PolyEdge 公共环境变量。
# 部署前复制为 deploy/.env，并替换占位值。不要提交真实密钥。
#
# 各服务的专属配置见 .env.api、.env.orderbook、.env.worker、.env.front。
# Polymarket live / Deposit Wallet 示例见 .env.polymarket.example。
# 后端运行参数已有代码默认值，首次启动后会写入 PostgreSQL runtime_config 表。

# ── 数据库 ──────────────────────────────────────────────────────────────────
# POLYEDGE_POSTGRES__URL：
# PostgreSQL 连接字符串，API、Worker、Orderbook 共用。生产/长期部署必须配置真实库；
# deploy.sh 会拒绝空值或仍包含 change-me 的占位值。
POLYEDGE_POSTGRES__URL=postgres://polyedge:change-me@host.docker.internal:5432/polyedge

# POLYEDGE_REDIS__URL：
# 可选 Redis 连接字符串。只有配置后才会使用；不配置时相关缓存/队列会走代码中的默认路径。
# POLYEDGE_REDIS__URL=redis://host.docker.internal:6379

# POLYEDGE_ALLOW_IN_MEMORY_DEPLOY：
# 仅一次性演示可设为 1，用来允许没有 PostgreSQL 的部署。实盘、共享环境或需要持久化时不要开启。
# POLYEDGE_ALLOW_IN_MEMORY_DEPLOY=1

# ── 认证 ────────────────────────────────────────────────────────────────────
# POLYEDGE_AUTH__DISABLED：
# 纯内网部署可设为 true，API 会跳过 console/connector/mode 鉴权并注入内部 admin 上下文；
# 前端和 API 分别部署在不同服务器时也不需要 dev-auth 头或 step-up code。公网/生产不要开启。
POLYEDGE_AUTH__DISABLED=true

# POLYEDGE_AUTH__STEP_UP_CODE：
# 仅当 POLYEDGE_AUTH__DISABLED=false 时需要。控制台受保护操作的 step-up 验证码（后端验证）。
# POLYEDGE_AUTH__STEP_UP_CODE=change-me

# ── 部署脚本 ────────────────────────────────────────────────────────────────
# POLYEDGE_API_IMAGE：
# 可选后端 API 镜像名/tag，用于 polyedge-api 服务。
# POLYEDGE_API_IMAGE=polyedge-api:local

# POLYEDGE_WORKER_IMAGE：
# 可选后端 Worker 镜像名/tag，用于 polyedge-worker 服务。
# POLYEDGE_WORKER_IMAGE=polyedge-worker:local

# POLYEDGE_ORDERBOOK_IMAGE：
# 可选 orderbook 独立镜像名/tag，用于 polyedge-orderbook 服务。
# POLYEDGE_ORDERBOOK_IMAGE=polyedge-orderbook:local

# POLYEDGE_FRONT_IMAGE：
# 可选前端镜像名/tag，用于 polyedge-front 服务。
# POLYEDGE_FRONT_IMAGE=polyedge-front:local

# POLYEDGE_LOG_FILE：
# 可选 deploy.sh 日志文件路径。用于 cron/CI 部署时落盘日志；不配置则按脚本默认处理。
# POLYEDGE_LOG_FILE=/home/polyedge/polyedge-deploy.log

# POLYEDGE_DEPLOY_LOCK_FILE：
# deploy.sh 互斥锁文件路径，用于防止 cron/CI 重叠执行。默认 /tmp/polyedge-deploy.lock。
# POLYEDGE_DEPLOY_LOCK_FILE=/tmp/polyedge-deploy.lock

# COMPOSE_PARALLEL_LIMIT：
# Docker Compose 构建并发数。低配服务器建议保持 1，降低磁盘 I/O 和内存峰值。
# COMPOSE_PARALLEL_LIMIT=1
