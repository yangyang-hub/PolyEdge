# PolyEdge Docker 部署环境变量示例。
# 部署前复制为 deploy/.env，并替换占位值。不要提交真实密钥。

# 前端容器发布到宿主机的监听地址。
POLYEDGE_FRONT_BIND=0.0.0.0
# 前端容器发布到宿主机的端口。
POLYEDGE_FRONT_PORT=33002
# API 容器发布到宿主机的监听地址。0.0.0.0 表示允许从宿主机外部网络访问；部署前请确认防火墙和反向代理策略。
POLYEDGE_API_BIND=0.0.0.0
# API 容器发布到宿主机的端口。
POLYEDGE_API_PORT=38001

# 前端容器内部访问后端 API 的基础地址。
POLYEDGE_API_BASE_URL=http://polyedge-api:38001
# 控制台路由保护模式。当前前端只保留 off；生产级 session provider 尚未接入。
POLYEDGE_CONSOLE_AUTH=off
# off 模式下，受保护控制台操作需要输入的 step-up code。部署时必须修改。
POLYEDGE_CONSOLE_STEP_UP_CODE=change-me

# 本地后端认证绕过开关。仅用于 prototype/shared-server 部署，并且需要 POLYEDGE_RUNTIME__ENVIRONMENT=local 和空的 POLYEDGE_AUTH__KEYS_JSON。
POLYEDGE_INTERNAL_AUTH_DEV_BYPASS=1
# 关闭 dev bypass 后，内部 JWT 使用的 issuer；必须与后端 POLYEDGE_AUTH__ISSUER 一致。
POLYEDGE_INTERNAL_AUTH_ISSUER=polyedge-nextjs
# 关闭 dev bypass 后，内部 JWT 使用的 audience；必须与后端 POLYEDGE_AUTH__AUDIENCE 一致。
POLYEDGE_INTERNAL_AUTH_AUDIENCE=polyedge-rust-api
# 内部 JWT 使用的 key id；必须匹配后端 POLYEDGE_AUTH__KEYS_JSON 中的一项。
POLYEDGE_INTERNAL_AUTH_KID=
# 用于签发内部 API JWT 的 Ed25519 私钥，可使用 base64 或 PEM。不要提交真实密钥。
POLYEDGE_INTERNAL_AUTH_PRIVATE_KEY=

# API 容器内的监听地址。
POLYEDGE_SERVER__HOST=0.0.0.0
# API 容器内的监听端口。
POLYEDGE_SERVER__PORT=38001
# 运行环境标识，用于日志和本地开发保护逻辑。
POLYEDGE_RUNTIME__ENVIRONMENT=local
# 初始系统模式。可选值：research、paper_trade、manual_confirm、live_auto、kill_switch_locked。
POLYEDGE_RUNTIME__INITIAL_MODE=manual_confirm

# PostgreSQL 连接地址。请替换为你的数据库地址；如果数据库在 Docker 宿主机上，compose 已启用 host.docker.internal。
POLYEDGE_POSTGRES__URL=postgres://polyedge:change-me@host.docker.internal:5432/polyedge
# 每个 API/Worker 容器的 PostgreSQL 连接池上限。多副本部署时按总实例数核算数据库 max_connections。
POLYEDGE_POSTGRES__MAX_CONNECTIONS=20
# Redis 连接地址。Redis 需要密码时可写成 redis://:pass@host.docker.internal:6379。
POLYEDGE_REDIS__URL=redis://host.docker.internal:6379

# 风险计算使用的参考净值。
POLYEDGE_RISK__EXPOSURE_REFERENCE_NAV=100.00
# 进程启动时的初始当日盈亏。
POLYEDGE_RISK__INITIAL_DAILY_PNL=0.00
# 进程启动时的初始总敞口比例，范围 0..1。
POLYEDGE_RISK__INITIAL_GROSS_EXPOSURE=0
# 进程启动时的初始净敞口比例，范围 0..1。
POLYEDGE_RISK__INITIAL_NET_EXPOSURE=0
# 进程启动时的初始未关闭风险告警数量。
POLYEDGE_RISK__INITIAL_OPEN_ALERTS=0
# 是否在启动时直接打开 kill switch。
POLYEDGE_RISK__INITIAL_KILL_SWITCH=false
# 信号进入执行候选前要求的最低置信度。
POLYEDGE_RISK__MIN_SIGNAL_CONFIDENCE=0.55
# 信号进入执行候选前要求的最低 edge。
POLYEDGE_RISK__MIN_EDGE_TO_EXECUTE=0.03
# 允许的最大未关闭风险告警数量，超过后阻止执行。
POLYEDGE_RISK__MAX_OPEN_ALERTS=3
# 最大当日亏损，单位 USD，超过后阻止执行。
POLYEDGE_RISK__MAX_DAILY_LOSS=5000.00
# 最大总敞口比例，范围 0..1。
POLYEDGE_RISK__MAX_GROSS_EXPOSURE=0.50
# 最大净敞口比例，范围 0..1。
POLYEDGE_RISK__MAX_NET_EXPOSURE=0.30

# Polymarket connector 模式。可选值：disabled、mock、live。真实凭证、账户资金和小额演练 runbook 完成前应保持 mock。
POLYEDGE_POLYMARKET__MODE=mock
# 记录在 connector/order 相关数据里的逻辑账户 id。
POLYEDGE_POLYMARKET__ACCOUNT_ID=polymarket_account
# Polymarket CLOB 签名使用的链 id；Polygon 为 137。
POLYEDGE_POLYMARKET__CHAIN_ID=137
# CLOB 签名类型。可选值：eoa、proxy、gnosis_safe。
POLYEDGE_POLYMARKET__SIGNATURE_TYPE=eoa
# proxy/safe 账户可使用的可选 funder 地址。
POLYEDGE_POLYMARKET__FUNDER=
# live connector 使用的私钥。不要提交真实密钥。
POLYEDGE_POLYMARKET__PRIVATE_KEY=
# Polymarket live 认证接口使用的 API key。
POLYEDGE_POLYMARKET__API_KEY=
# Polymarket live 认证接口使用的 API secret。
POLYEDGE_POLYMARKET__API_SECRET=
# Polymarket live 认证接口使用的 API passphrase。
POLYEDGE_POLYMARKET__API_PASSPHRASE=
# Polymarket CLOB REST 地址，用于盘口和订单接口。
POLYEDGE_POLYMARKET__CLOB_HOST=https://clob.polymarket.com
# Polymarket market websocket 地址，用于用户/市场事件消费者。
POLYEDGE_POLYMARKET__WS_HOST=wss://ws-subscriptions-clob.polymarket.com/ws/market
# Polymarket Gamma 地址，用于市场元数据发现。
POLYEDGE_POLYMARKET__GAMMA_HOST=https://gamma-api.polymarket.com
# Polymarket data API 地址，用于成交、交易和账户数据。
POLYEDGE_POLYMARKET__DATA_API_HOST=https://data-api.polymarket.com
# 每次订单状态轮询最多检查的 Polymarket submitted 订单数量。
POLYEDGE_POLYMARKET__ORDER_STATUS_POLL_LIMIT=100
# 每次回补最多处理的 Polymarket fill 数量。
POLYEDGE_POLYMARKET__FILL_POLL_LIMIT=100
# 单个 websocket 消费者最多订阅的 instrument 数量。
POLYEDGE_POLYMARKET__WS_MAX_INSTRUMENTS=100
# websocket 空闲达到多少秒后输出告警日志。
POLYEDGE_POLYMARKET__WS_IDLE_WARN_SECS=15
# websocket 数据超过多少秒未更新后视为 stale。
POLYEDGE_POLYMARKET__WS_STALE_AFTER_SECS=60

# 是否启用只读套利雷达 worker loop。套利雷达只做机会发现、记录、校验、分析和推送，不会下单或创建 execution request。
POLYEDGE_ARBITRAGE__ENABLED=false
# poll-arbitrage-radar 两轮扫描之间的间隔秒数。
POLYEDGE_ARBITRAGE__POLL_INTERVAL_SECS=5
# 每轮最多扫描的 open market 数量。
POLYEDGE_ARBITRAGE__SCAN_LIMIT=100
# 写入 scan 记录的扫描器版本，用于后续对比。
POLYEDGE_ARBITRAGE__SCANNER_VERSION=v1
# 盘口来源。可选值：market_snapshot、polymarket。polymarket 需要真实公网 token id；fixture 演示 token 会返回 404。
POLYEDGE_ARBITRAGE__BOOK_SOURCE=market_snapshot
# 历史分析回看窗口，单位小时。
POLYEDGE_ARBITRAGE__ANALYSIS_LOOKBACK_HOURS=24
# 机会校验允许的最大盘口年龄，单位毫秒。
POLYEDGE_ARBITRAGE__MAX_BOOK_AGE_MS=10000
# observed 机会超过多少秒后标记为 expired。
POLYEDGE_ARBITRAGE__OPPORTUNITY_TTL_SECS=60
# 套利 SSE/outbox 事件保留时长，单位小时。
POLYEDGE_ARBITRAGE__EVENT_RETENTION_HOURS=24
# 机会校验要求的最低 gross edge，范围 0..1。
POLYEDGE_ARBITRAGE__MIN_GROSS_EDGE=0.005
# 机会校验要求的最低撮合盘口容量。
POLYEDGE_ARBITRAGE__MIN_CAPACITY=1
# 校验时从 gross edge 中扣除的 fee buffer。
POLYEDGE_ARBITRAGE__FEE_BUFFER=0.005
# 校验时从 gross edge 中扣除的 slippage buffer。
POLYEDGE_ARBITRAGE__SLIPPAGE_BUFFER=0.005

# 是否允许 worker 周期性运行 rewards bot 模拟。当前仅生成模拟挂单计划，不会实盘下单。
POLYEDGE_REWARDS__ENABLED=false
# poll-reward-bot 两轮模拟之间的间隔秒数。
POLYEDGE_REWARDS__POLL_INTERVAL_SECS=60

# 是否启用 worker 新闻抓取。为 false 时，poll-news 不会发起抓取。
POLYEDGE_NEWS__ENABLED=false
# poll-news 两轮抓取之间的间隔秒数。
POLYEDGE_NEWS__POLL_INTERVAL_SECS=60
# 单个 RSS/Atom source 请求超时时间，单位秒。
POLYEDGE_NEWS__REQUEST_TIMEOUT_SECS=10
# 每个 source 单次最多接收的 feed item 数量。
POLYEDGE_NEWS__MAX_ITEMS_PER_SOURCE=50
# 新闻源 JSON 数组。
POLYEDGE_NEWS__SOURCES_JSON=[]

# polyedge-worker 常驻服务配置。API 不会运行后台任务，因此可多副本部署。
POLYEDGE_WORKER__INGEST_FIXTURES_ON_START=false
# 是否启用 poll-news。仍要求 POLYEDGE_NEWS__ENABLED=true 且配置了新闻源。
POLYEDGE_WORKER__POLL_NEWS=false
# 是否定期把 raw news 提升为 events/evidences。
POLYEDGE_WORKER__PROMOTE_NEWS_EVENTS=false
# 是否启用 poll-arbitrage-radar。仍要求 POLYEDGE_ARBITRAGE__ENABLED=true。
POLYEDGE_WORKER__POLL_ARBITRAGE_RADAR=false
# 是否定时写入套利历史分析。
POLYEDGE_WORKER__ANALYZE_ARBITRAGE_OPPORTUNITIES=false
# 是否定期运行 rewards bot 模拟。仍要求 POLYEDGE_REWARDS__ENABLED=true。
POLYEDGE_WORKER__POLL_REWARD_BOT=false
# 是否定期提交待执行队列。开启前确认 runtime mode、connector mode 和风控配置。
POLYEDGE_WORKER__DRAIN_EXECUTION_QUEUE=false
# 是否定期轮询 paper order submitted -> open。
POLYEDGE_WORKER__POLL_PAPER_ORDER_STATUSES=false
# 是否定期回写 paper fills。
POLYEDGE_WORKER__RECONCILE_PAPER_FILLS=false
# 是否定期轮询 Polymarket order status。
POLYEDGE_WORKER__POLL_POLYMARKET_ORDER_STATUSES=false
# 是否定期回写 Polymarket fills。
POLYEDGE_WORKER__RECONCILE_POLYMARKET_FILLS=false
# 是否消费 Polymarket authenticated user websocket。要求 POLYEDGE_POLYMARKET__MODE=live。
POLYEDGE_WORKER__CONSUME_POLYMARKET_USER_EVENTS=false
POLYEDGE_WORKER__NEWS_PROMOTION_INTERVAL_SECS=60
POLYEDGE_WORKER__ARBITRAGE_ANALYSIS_INTERVAL_SECS=300
POLYEDGE_WORKER__EXECUTION_DRAIN_INTERVAL_SECS=5
POLYEDGE_WORKER__ORDER_STATUS_POLL_INTERVAL_SECS=15
POLYEDGE_WORKER__FILL_RECONCILIATION_INTERVAL_SECS=15
POLYEDGE_WORKER__POLYMARKET_USER_EVENT_RESTART_INTERVAL_SECS=5
POLYEDGE_WORKER__TASK_LIMIT=100

# 后端内部 JWT 验签器要求的 issuer。
POLYEDGE_AUTH__ISSUER=polyedge-nextjs
# 后端内部 JWT 验签器要求的 audience。
POLYEDGE_AUTH__AUDIENCE=polyedge-rust-api
# JWT 允许的时钟偏移秒数。
POLYEDGE_AUTH__CLOCK_SKEW_SECS=30
# read/query token 允许的最大 TTL，单位秒。
POLYEDGE_AUTH__MAX_QUERY_TTL_SECS=60
# write/action token 允许的最大 TTL，单位秒。
POLYEDGE_AUTH__MAX_WRITE_TTL_SECS=30
# step-up scope 允许的最大时间窗口，单位秒。
POLYEDGE_AUTH__MAX_STEP_UP_WINDOW_SECS=600
# 已撤销 session id 列表，逗号分隔。
POLYEDGE_AUTH__REVOKED_SESSIONS=
# 此 RFC3339 时间之后，已有 session 必须重新认证。
POLYEDGE_AUTH__FORCE_REAUTH_AFTER=2026-01-01T00:00:00Z
# Ed25519 公钥 JSON 数组。只有本地 dev-auth 模式才应留空数组。
POLYEDGE_AUTH__KEYS_JSON=[]
