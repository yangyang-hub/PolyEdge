# PolyEdge Docker 部署环境变量示例。
# 部署前复制为 deploy/.env，并替换占位值。不要提交真实密钥。
#
# 后端运行参数已有代码默认值，首次启动后会写入 PostgreSQL runtime_config 表。
# 服务器部署只在确实需要覆盖默认值时，才额外添加对应环境变量。

# API/worker 持久化状态所需。除非显式设置 POLYEDGE_ALLOW_IN_MEMORY_DEPLOY=1，
# 部署脚本会拒绝空值或占位值。
POLYEDGE_POSTGRES__URL=postgres://polyedge:change-me@host.docker.internal:5432/polyedge

# 受保护控制台操作所需。部署时必须改成专用值。
POLYEDGE_CONSOLE_STEP_UP_CODE=change-me

# 可选：Redis 只有配置后才会使用。
# POLYEDGE_REDIS__URL=redis://host.docker.internal:6379

# 可选：宿主机端口绑定。docker-compose.yml 已内置相同默认值。
# POLYEDGE_FRONT_BIND=0.0.0.0
# POLYEDGE_FRONT_PORT=33002
# POLYEDGE_API_BIND=0.0.0.0
# POLYEDGE_API_PORT=38001
