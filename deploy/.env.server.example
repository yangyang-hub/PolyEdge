# PolyEdge 单体后端环境变量。复制为 deploy/.env.server。
# 该进程同时提供 HTTP API、人工策略执行、目标 token 盘口轮询和多钱包账户对账。
# 不要把真实钱包密钥提交到仓库或放入前端环境。

# ── Compose 镜像与端口映射 ───────────────────────────────────────────────
# POLYEDGE_SERVER_IMAGE=polyedge-server:local
# POLYEDGE_SERVER_BIND=0.0.0.0
# POLYEDGE_SERVER_PORT=38001

# ── HTTP / 存储 ──────────────────────────────────────────────────────────
POLYEDGE_SERVER__HOST=0.0.0.0
POLYEDGE_SERVER__PORT=38001
# 单请求体上限；超出后由 API 拒绝。
POLYEDGE_SERVER__MAX_BODY_BYTES=1048576

# Browser CORS 精确 allowlist，逗号分隔，不得使用 *、路径或 query。
POLYEDGE_CORS__ALLOWED_ORIGINS=http://192.168.31.5:33002

# 新部署直接初始化当前 schema，不兼容旧数据库。
POLYEDGE_POSTGRES__URL=postgres://poly-edge:change-me@host.docker.internal:5432/poly-edge
POLYEDGE_POSTGRES__MAX_CONNECTIONS=20

# ── Runtime / 鉴权 ───────────────────────────────────────────────────────
POLYEDGE_RUNTIME__ENVIRONMENT=production

# 当前静态前端没有登录/session/JWT 获取链路。关闭鉴权只能用于 VPN、私网 ACL
# 或可信访问代理形成的边界；CORS 本身不是鉴权。
POLYEDGE_AUTH__DISABLED=true
POLYEDGE_AUTH__ALLOW_INSECURE_PRIVATE_DEPLOY=true

# 启用认证时使用静态 Bearer API token；建议由可信反向代理负责用户身份与短期凭证。
# POLYEDGE_AUTH__API_TOKEN=replace-with-a-long-random-token
# 危险操作的二次确认码；production 必填，并应通过秘密管理系统注入。
POLYEDGE_AUTH__STEP_UP_CODE=replace-with-a-long-random-step-up-code

# ── 人工目标市场盘口 ────────────────────────────────────────────────────
# 只订阅已启用人工策略、开放订单和持仓涉及的 token；不扫描全市场、不预热候选市场。
POLYEDGE_TARGETED_ORDERBOOK__MAX_TOKENS=1000
POLYEDGE_TARGETED_ORDERBOOK__POLL_INTERVAL_MS=10000

# ── 多钱包执行 ──────────────────────────────────────────────────────────
# 钱包间有界并行；同一钱包的动作仍由钱包级执行器串行化。
POLYEDGE_EXECUTION__WALLET_CONCURRENCY=4
POLYEDGE_EXECUTION__RECONCILE_INTERVAL_MS=2000

# credential_ref 的 secret resolver。env backend 会把 credential_ref 规范化为大写，
# 非字母数字字符替换为下划线，再拼到 ENV_PREFIX 后读取环境变量。
POLYEDGE_WALLET_SECRETS__ENV_PREFIX=POLYEDGE_WALLET_SECRET__

# 每个钱包 secret 使用 JSON；变量名示例对应 credential_ref `maker-primary`。
# 不要取消注释后提交真实值。
# POLYEDGE_WALLET_SECRET__MAKER_PRIMARY={"private_key":"0x...","api_key":"...","api_secret":"...","api_passphrase":"..."}

# ── Polymarket endpoints ─────────────────────────────────────────────────
# 账户地址、签名类型和 funder 属于数据库中的 wallet account；密钥/CLOB 凭证由上面的
# credential_ref resolver 提供，不再通过单账户 POLYEDGE_POLYMARKET__ACCOUNT_ID/PRIVATE_KEY 配置。
# POLYEDGE_POLYMARKET__CLOB_HOST=https://clob.polymarket.com
# POLYEDGE_POLYMARKET__DATA_API_HOST=https://data-api.polymarket.com
# POLYEDGE_POLYMARKET__CHAIN_ID=137
