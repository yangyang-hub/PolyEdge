# PolyEdge 单体后端环境变量。复制为 deploy/.env.server。
# 该进程同时提供 HTTP API、人工策略执行、目标 token 盘口轮询和多钱包账户对账。
# 不要把真实钱包密钥提交到仓库或放入前端环境。

# ── Compose 镜像与端口映射 ───────────────────────────────────────────────
# POLYEDGE_SERVER_IMAGE=polyedge-server:local
# API 仅在 Compose 网络暴露给前端 Nginx，不映射宿主端口；标准部署固定使用
# POLYEDGE_SERVER__HOST=0.0.0.0 与 POLYEDGE_SERVER__PORT=38001。
# Compose 宿主机上的 RSA 私钥路径；文件权限应为 0600，并只读挂载到固定容器路径。
# POLYEDGE_WALLET_IMPORT_PRIVATE_KEY_FILE=./secrets/polyedge-wallet-import-private.pem
# Compose 宿主机上的 base64 storage key 文件路径；权限应为 0600，解码后必须为 32 bytes。
# POLYEDGE_WALLET_STORAGE_KEY_FILE=./secrets/polyedge-wallet-storage-key

# ── HTTP / 存储 ──────────────────────────────────────────────────────────
POLYEDGE_SERVER__HOST=0.0.0.0
POLYEDGE_SERVER__PORT=38001
# 单请求体上限；超出后由 API 拒绝。
POLYEDGE_SERVER__MAX_BODY_BYTES=1048576

# 浏览器与 Nginx 使用同源 Cookie session。生产必须改为实际 HTTPS origin。
POLYEDGE_PUBLIC_ORIGIN=https://polyedge.example.com
POLYEDGE_CORS__ALLOWED_ORIGINS=https://polyedge.example.com

# 新部署直接初始化当前 schema，不兼容旧数据库。
POLYEDGE_POSTGRES__URL=postgres://poly-edge:change-me@host.docker.internal:5432/poly-edge
POLYEDGE_POSTGRES__MAX_CONNECTIONS=20

# ── Runtime / 鉴权 ───────────────────────────────────────────────────────
# 只接受 local 或 production；未知值会使 server 启动失败。
POLYEDGE_RUNTIME__ENVIRONMENT=production

# 环境管理员是唯一 bootstrap 身份；PASSWORD_HASH 必须为 Argon2id PHC 字符串。
POLYEDGE_BOOTSTRAP_ADMIN__USERNAME=admin
POLYEDGE_BOOTSTRAP_ADMIN__DISPLAY_NAME=PolyEdge Administrator
POLYEDGE_BOOTSTRAP_ADMIN__PASSWORD_HASH=replace-with-argon2id-phc-hash
POLYEDGE_BOOTSTRAP_ADMIN__CREDENTIAL_VERSION=1
POLYEDGE_AUTH__SESSION_IDLE_SECONDS=1800
POLYEDGE_AUTH__SESSION_ABSOLUTE_SECONDS=28800
POLYEDGE_AUTH__ACTIVATION_TTL_SECONDS=86400
POLYEDGE_AUTH__RECENT_AUTH_TTL_SECONDS=300

# ── 人工目标市场盘口 ────────────────────────────────────────────────────
# 只订阅已启用人工策略、开放订单和持仓涉及的 token；不扫描全市场、不预热候选市场。
POLYEDGE_TARGETED_ORDERBOOK__MAX_TOKENS=1000
POLYEDGE_TARGETED_ORDERBOOK__POLL_INTERVAL_MS=10000

# ── 多钱包执行 ──────────────────────────────────────────────────────────
# 钱包间有界并行；同一钱包的动作仍由钱包级执行器串行化。
POLYEDGE_EXECUTION__WALLET_CONCURRENCY=4
POLYEDGE_EXECUTION__RECONCILE_INTERVAL_MS=2000

# 浏览器导入使用 RSA-OAEP，数据库使用独立 AES-256-GCM storage key。
# 以下两个容器路径由 Compose 固定，不能在标准部署中改名。
# PEM 文件应通过只读 secret mount 提供；storage key 是 32-byte 随机值的标准 base64。
POLYEDGE_WALLET_CRYPTO__TRANSPORT_PRIVATE_KEY_PEM_FILE=/run/secrets/polyedge-wallet-import-private.pem
POLYEDGE_WALLET_CRYPTO__TRANSPORT_KEY_ID=wallet-import-rsa-v1
POLYEDGE_WALLET_CRYPTO__STORAGE_KEY_ID=wallet-storage-aes-v1
POLYEDGE_WALLET_CRYPTO__STORAGE_KEY_FILE=/run/secrets/polyedge-wallet-storage-key
POLYEDGE_WALLET_CRYPTO__IMPORT_CONTEXT_TTL_SECONDS=300
POLYEDGE_WALLET_CRYPTO__MAX_IMPORT_CONTEXTS=1024

# ── Polymarket endpoints ─────────────────────────────────────────────────
# 账户地址、签名类型和 funder 属于数据库 wallet；加密凭证只在执行时短暂解密。
# POLYEDGE_POLYMARKET__CLOB_HOST=https://clob.polymarket.com
# POLYEDGE_POLYMARKET__DATA_API_HOST=https://data-api.polymarket.com
# POLYEDGE_POLYMARKET__CHAIN_ID=137
